<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head') %>
    <!-- Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
</head>





<body>





  <!-- ===== DASHBOARD NAVBAR ===== -->
  <%- include('partials/dash-navbar') %>








    <!-- Main Dashboard Layout -->


    <div class="dashboard" id="dashboardLayout">





      <!-- ===== SIDEBAR ===== -->


      <aside class="sidebar" id="sidebar">


        <div class="sidebar__header">


          <div class="sidebar__role-title" id="roleTitle">Student (CSPC Email)</div>


          <span class="sidebar__role-badge" id="roleBadge">CSPC Verified</span>


        </div>





        <nav class="sidebar__nav" id="sidebarNav">


          <!-- Dynamically rendered by JS -->


        </nav>





        <div class="sidebar__footer">


          <div class="sidebar__user">


            <div class="sidebar__avatar"
              style="width:36px;height:36px;border-radius:50%;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;">


              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">


                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />


                <circle cx="12" cy="7" r="4" />


              </svg>


            </div>


            <div class="sidebar__user-info">


              <div class="sidebar__user-name" id="sidebarName">Aaron V. Lasprillas</div>


              <div class="sidebar__user-email" id="sidebarEmail">aaron@cspc.edu.ph</div>


            </div>


          </div>


        </div>





      </aside>





      <!-- ===== MAIN CONTENT PANEL ===== -->


      <main class="dash-panel" id="dashPanel">


        <div class="dash-panel__header">


          <h1 class="dash-panel__greeting" id="panelGreeting">Welcome, Aaron!</h1>


          <p class="dash-panel__role-label" id="panelRoleLabel">Student (CSPC) — CSPC Verified</p>


        </div>





        <!-- ===== CONTENT CONTAINER ===== -->


        <div id="contentContainer">


          <!-- All sections rendered here by EJS-style templating engine -->


        </div>


      </main>


    </div>





    <!-- Mobile Sidebar Toggle -->


    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">


      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round">


        <line x1="3" y1="12" x2="21" y2="12" />


        <line x1="3" y1="6" x2="21" y2="6" />


        <line x1="3" y1="18" x2="21" y2="18" />


      </svg>


    </button>





    <!-- Theme Toggle -->


    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">


      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">


        <circle cx="12" cy="12" r="5" />


        <line x1="12" y1="1" x2="12" y2="3" />


        <line x1="12" y1="21" x2="12" y2="23" />


        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />


        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />


        <line x1="1" y1="12" x2="3" y2="12" />


        <line x1="21" y1="12" x2="23" y2="12" />


        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />


        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />


      </svg>


      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">


        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />


      </svg>


    </button>





    <!-- =========================================================


       EJS-STYLE TEMPLATES (rendered by client-side JS engine)


       ========================================================= -->





    <!-- OVERVIEW: Student CSPC -->


    <script type="text/ejs-template" id="tmpl-student-cspc-overview">


    <div class="stat-cards">


      <div class="stat-card">


        <div class="stat-card__icon stat-card__icon--blue">📚</div>


        <div class="stat-card__label">Course</div>


        <div class="stat-card__value stat-card__value--sm"><%%= studentProfile.course %%></div>


      </div>


      <div class="stat-card">


        <div class="stat-card__icon stat-card__icon--green">📅</div>


        <div class="stat-card__label">Year & Section</div>


        <div class="stat-card__value stat-card__value--sm"><%%= studentProfile.yearLevel %%> — <%%= studentProfile.section %%></div>


      </div>


      <div class="stat-card">


        <div class="stat-card__icon stat-card__icon--gold">🏫</div>


        <div class="stat-card__label">Assigned Room</div>


        <div class="stat-card__value stat-card__value--sm"><%%= studentProfile.assignedRoom %%></div>


      </div>


      <div class="stat-card">


        <div class="stat-card__icon stat-card__icon--red">📈</div>


        <div class="stat-card__label">GWA</div>


        <div class="stat-card__value"><%%= studentProfile.gwa %%></div>


      </div>


    </div>


    <div class="info-grid">


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">Enrollment Status</h3><span class="status-badge status-badge--enrolled"><%%= studentProfile.enrollmentStatus %%></span></div>


        <div class="panel-card__body">


          <p style="font-size:0.88rem;color:var(--gray-600);"><strong><%%= studentProfile.semester %%></strong><br>Status: <span style="color:var(--green-accent);font-weight:600;"><%%= studentProfile.status %%></span></p>


        </div>


      </div>


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">Quick Links</h3></div>


        <div class="panel-card__body">


          <div style="display:flex;flex-direction:column;gap:8px;">


            <button class="btn btn--primary btn--sm" style="justify-content:flex-start;" onclick="switchSection('buildings')">🏢 Navigate Buildings</button>


            <a href="/map" class="btn btn--outline btn--sm" style="justify-content:flex-start;text-transform:none;">🗺️ Campus Map</a>


          </div>


        </div>


      </div>


    </div>


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Latest News</h3></div>


      <div class="panel-card__body">


        <%% for(var i=0; i<news.length && i<2; i++) { %%>


          <div class="news-item">


            <span class="news-item__category"><%%= news[i].category %%></span>


            <div class="news-item__title"><%%= news[i].title %%></div>


            <div class="news-item__date"><%%= news[i].date %%></div>


            <p class="news-item__excerpt"><%%= news[i].excerpt %%></p>


          </div>


        <%% } %%>


      </div>


    </div>


  </script>





    <!-- PROFILE: Student CSPC -->


    <script type="text/ejs-template" id="tmpl-student-cspc-profile">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Personal Information</h3></div>


      <div class="panel-card__body">


        <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:1.5rem;">


          <div style="width:100px;height:100px;border-radius:50%;overflow:hidden;background:var(--gray-100);border:3px solid var(--navy-200);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(0,0,0,0.1);">


            <%% if(studentProfile.profileImage) { %%>


              <img src="<%%= studentProfile.profileImage %%>" alt="Profile Picture" style="width:100%;height:100%;object-fit:cover;">


            <%% } else { %%>


              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>


            <%% } %%>


          </div>


          <div style="margin-top:0.75rem;font-weight:700;font-size:1.05rem;color:var(--navy-900);"><%%= studentProfile.name %%></div>


          <div style="font-size:0.82rem;color:var(--gray-500);margin-top:2px;"><%%= studentProfile.email %%></div>


        </div>


        <div class="profile-info">


          <div class="profile-info__item"><span class="profile-info__label">Full Name</span><span class="profile-info__value"><%%= studentProfile.name %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Student ID</span><span class="profile-info__value"><%%= studentProfile.studentId %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Email</span><span class="profile-info__value"><%%= studentProfile.email %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Course</span><span class="profile-info__value"><%%= studentProfile.course %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Year Level</span><span class="profile-info__value"><%%= studentProfile.yearLevel %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Section</span><span class="profile-info__value"><%%= studentProfile.section %%></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Status</span><span class="profile-info__value"><span class="status-badge status-badge--active"><%%= studentProfile.status %%></span></span></div>


          <div class="profile-info__item"><span class="profile-info__label">Semester</span><span class="profile-info__value"><%%= studentProfile.semester %%></span></div>


        </div>


      </div>


    </div>


  </script>





    <!-- ENROLLMENT: Student CSPC -->


    <script type="text/ejs-template" id="tmpl-student-cspc-enrollment">


    <div class="stat-cards">


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--blue">📄</div><div class="stat-card__label">Enrollment Status</div><div class="stat-card__value stat-card__value--sm"><%%= studentProfile.enrollmentStatus %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--green">📅</div><div class="stat-card__label">Semester</div><div class="stat-card__value stat-card__value--sm"><%%= studentProfile.semester %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--gold">⭐</div><div class="stat-card__label">GWA</div><div class="stat-card__value"><%%= studentProfile.gwa %%></div></div>


    </div>


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Enrolled Subjects</h3></div>


      <div class="panel-card__body">


        <table class="data-table"><thead><tr><th>Subject</th><th>Room</th><th>Schedule</th><th>Instructor</th></tr></thead><tbody>


        <%% for(var i=0; i<schedule.length; i++) { %%>


          <tr><td><%%= schedule[i].subject %%></td><td><%%= schedule[i].room %%></td><td><%%= schedule[i].day %%> <%%= schedule[i].time %%></td><td><%%= schedule[i].instructor %%></td></tr>


        <%% } %%>


        </tbody></table>


      </div>


    </div>


  </script>





    <!-- SCHEDULE: Student CSPC -->


    <script type="text/ejs-template" id="tmpl-student-cspc-schedule">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Class Schedule — <%%= studentProfile.semester %%></h3></div>


      <div class="panel-card__body">


        <table class="data-table"><thead><tr><th>Time</th><th>Subject</th><th>Room</th><th>Day</th><th>Instructor</th></tr></thead><tbody>


        <%% for(var i=0; i<schedule.length; i++) { %%>


          <tr><td><%%= schedule[i].time %%></td><td><strong><%%= schedule[i].subject %%></strong></td><td><%%= schedule[i].room %%></td><td><%%= schedule[i].day %%></td><td><%%= schedule[i].instructor %%></td></tr>


        <%% } %%>


        </tbody></table>


      </div>


    </div>


  </script>





    <!-- NEWS (shared) -->


    <script type="text/ejs-template" id="tmpl-shared-news">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">News & Announcements</h3></div>


      <div class="panel-card__body">


        <%% for(var i=0; i<news.length; i++) { %%>


          <div class="news-item">


            <span class="news-item__category"><%%= news[i].category %%></span>


            <div class="news-item__title"><%%= news[i].title %%></div>


            <div class="news-item__date"><%%= news[i].date %%></div>


            <p class="news-item__excerpt"><%%= news[i].excerpt %%></p>


          </div>


        <%% } %%>


      </div>


    </div>


  </script>





    <!-- MAP (shared) -->


    <script type="text/ejs-template" id="tmpl-shared-map">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Campus Map — CSPC Nabua</h3><a href="/map" class="btn btn--primary btn--sm">Open Full Map</a></div>


      <div class="panel-card__body">


        <div id="dashLeafletMap" style="width:100%;height:350px;border-radius:12px;"></div>


      </div>


    </div>


  </script>





    <!-- NAVIGATE BUILDINGS: Student CSPC -->


    <script type="text/ejs-template" id="tmpl-student-buildings">


    <div class="panel-card" style="margin-bottom:var(--space-lg);">


      <div class="panel-card__header"><h3 class="panel-card__title">Navigate Campus Buildings</h3></div>


      <div class="panel-card__body">


        <p style="font-size:.85rem;color:var(--gray-500);margin-bottom:var(--space-md);">Browse all campus buildings. Click "View Inside" to explore floors and rooms.</p>


        <div class="stat-cards" id="studentBuildingGrid" style="margin-bottom:0;"></div>


      </div>


    </div>


    <div id="studentBuildingDetail" style="display:none;"></div>


  </script>





    <!-- OVERVIEW: Student Non-CSPC -->


    <script type="text/ejs-template" id="tmpl-student-non-cspc-overview">


    <div class="stat-cards">


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--blue">🏛️</div><div class="stat-card__label">Campus Offices</div><div class="stat-card__value stat-card__value--sm"><%%= campusOffices.length %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--green">📋</div><div class="stat-card__label">Admission</div><div class="stat-card__value stat-card__value--sm">Open</div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--gold">🗺️</div><div class="stat-card__label">Campus Map</div><div class="stat-card__value stat-card__value--sm">Available</div></div>


    </div>


    <div class="panel-card" style="margin-bottom:var(--space-xl);">


      <div class="panel-card__header"><h3 class="panel-card__title">Welcome, Future Cavalier!</h3></div>


      <div class="panel-card__body"><p style="color:var(--gray-600);font-size:0.9rem;line-height:1.7;">Welcome to CampusSphere! As a prospective student, you can explore important campus offices, learn about the admission process, and navigate the campus map. For full features, enroll and sign in with your <strong>@cspc.edu.ph</strong> email.</p></div>


    </div>


  </script>





    <!-- OFFICES: Student Non-CSPC -->


    <script type="text/ejs-template" id="tmpl-student-non-cspc-offices">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Important Campus Offices & Entry Points</h3></div>


      <div class="panel-card__body">


        <%% for(var i=0; i<campusOffices.length; i++) { %%>


          <div class="news-item">


            <div class="news-item__title"><%%= campusOffices[i].name %%></div>


            <div class="news-item__date">📍 <%%= campusOffices[i].location %%></div>


            <p class="news-item__excerpt"><%%= campusOffices[i].description %%></p>


            <%% if(campusOffices[i].hours) { %%><p style="font-size:0.8rem;color:var(--green-accent);font-weight:600;margin-top:4px;">🕐 <%%= campusOffices[i].hours %%></p><%% } %%>


          </div>


        <%% } %%>


      </div>


    </div>


  </script>





    <!-- ADMISSION: Student Non-CSPC -->


    <script type="text/ejs-template" id="tmpl-student-non-cspc-admission">


    <div class="info-grid">


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">Admission Requirements</h3></div>


        <div class="panel-card__body">


          <div style="display:flex;flex-direction:column;gap:8px;">


            <%% for(var i=0; i<admissionInfo.requirements.length; i++) { %%>


              <div style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:var(--gray-700);">


                <span style="color:var(--navy-600);font-weight:700;">✔</span> <%%= admissionInfo.requirements[i] %%>


              </div>


            <%% } %%>


          </div>


        </div>


      </div>


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">How to Apply</h3></div>


        <div class="panel-card__body">


          <div style="display:flex;flex-direction:column;gap:10px;">


            <%% for(var i=0; i<admissionInfo.steps.length; i++) { %%>


              <p style="font-size:0.88rem;color:var(--gray-700);margin:0;"><%%= admissionInfo.steps[i] %%></p>


            <%% } %%>


          </div>


          <div style="margin-top:var(--space-lg);padding:var(--space-md);background:rgba(30,77,140,0.06);border-radius:var(--radius-md);">


            <p style="font-size:0.85rem;color:var(--navy-700);font-weight:600;margin:0 0 4px;">📅 Deadline: <%%= admissionInfo.deadline %%></p>


            <p style="font-size:0.82rem;color:var(--gray-600);margin:0;">📧 Contact: <%%= admissionInfo.contactEmail %%></p>


          </div>


        </div>


      </div>


    </div>


  </script>





    <!-- OVERVIEW: Instructor -->


    <script type="text/ejs-template" id="tmpl-instructor-overview">


    <div class="stat-cards">


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--blue">👨‍🏫</div><div class="stat-card__label">Position</div><div class="stat-card__value stat-card__value--sm"><%%= instructorProfile.position %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--green">🏢</div><div class="stat-card__label">Department</div><div class="stat-card__value stat-card__value--sm"><%%= instructorProfile.department %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--gold">🚪</div><div class="stat-card__label">Assigned Rooms</div><div class="stat-card__value"><%%= instructorProfile.assignedRooms.length %%></div></div>


      <div class="stat-card"><div class="stat-card__icon stat-card__icon--red">✅</div><div class="stat-card__label">Status</div><div class="stat-card__value stat-card__value--sm"><%%= instructorProfile.status %%></div></div>


    </div>


    <div class="info-grid">


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">Assigned Rooms & Schedule</h3></div>


        <div class="panel-card__body">


          <table class="data-table"><thead><tr><th>Room</th><th>Subject</th><th>Schedule</th></tr></thead><tbody>


          <%% for(var i=0; i<instructorProfile.assignedRooms.length; i++) { %%>


            <tr><td><%%= instructorProfile.assignedRooms[i].room %%></td><td><strong><%%= instructorProfile.assignedRooms[i].subject %%></strong></td><td><%%= instructorProfile.assignedRooms[i].schedule %%></td></tr>


          <%% } %%>


          </tbody></table>


        </div>


      </div>


      <div class="panel-card">


        <div class="panel-card__header"><h3 class="panel-card__title">Quick Links</h3></div>


        <div class="panel-card__body">


          <div style="display:flex;flex-direction:column;gap:8px;">


            <button class="btn btn--primary btn--sm" style="justify-content:flex-start;" onclick="switchSection('buildings')">🏢 Navigate Buildings</button>


            <button class="btn btn--outline btn--sm" style="justify-content:flex-start;text-transform:none;" onclick="switchSection('all-rooms')">🚪 View All Rooms</button>


            <a href="/map" class="btn btn--outline btn--sm" style="justify-content:flex-start;text-transform:none;">🗺️ Campus Map</a>


          </div>


        </div>


      </div>


    </div>


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Latest Faculty News</h3></div>


      <div class="panel-card__body">


        <%% for(var i=0; i<instructorNews.length && i<2; i++) { %%>


          <div class="news-item">


            <span class="news-item__category"><%%= instructorNews[i].category %%></span>


            <div class="news-item__title"><%%= instructorNews[i].title %%></div>


            <div class="news-item__date"><%%= instructorNews[i].date %%></div>


            <p class="news-item__excerpt"><%%= instructorNews[i].excerpt %%></p>


          </div>


        <%% } %%>


      </div>


    </div>


  </script>





    <!-- PROFILE: Instructor -->


    <script type="text/ejs-template" id="tmpl-instructor-profile">


    <div class="panel-card">


      <div class="panel-card__header"><h3 class="panel-card__title">Instructor Profile</h3></div>


      <div class="panel-card__body">


        <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:1.5rem;">


          <div style="width:100px;height:100px;border-radius:50%;overflow:hidden;background:var(--gray-100);border:3px solid var(--navy-200);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(0,0,0,0.1);">


            <%% if(instructorProfile.profileImage) { %%>


              <img src="<%%= instructorProfile.profileImage %%>" alt="Profile Picture" style="width:100%;height:100%;object-fit:cover;">


            <%% } else { %%>


              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>


            <%% } %%>


          </div>


          <div style="margin-top:0.75rem;font-weight:700;font-size:1.05rem;color:var(--navy-900);"><%%= instructorProfile.name %%></div>


          <div style="font-size:0.82rem;color:var(--gray-500);margin-top:2px;"><%%= instructorProfile.email %%></div>


        </div>


        <div class="profile-info">


          <div class="profile-info__item"><span class="profile-info__label">Full Name</span><span class="profile-info__value"><%%= instructorProfile.name %%></span></div>


