    <!-- =========================================================


       DATA + EJS TEMPLATE ENGINE


       ========================================================= -->


    <script src="/js/data.js"></script>


    <script>


      // ======= CLIENT-SIDE EJS TEMPLATE ENGINE =======


      function ejsRender(templateStr, data) {


        // Process <%% code %%>, <%%= output %%>, <%%- raw %%>


        let fn = 'var __o = [];\n';


        fn += 'with(data) {\n';


        let cursor = 0;


        const re = /<%%(-|=)?([\s\S]*?)%%>/g;


        let match;





        while ((match = re.exec(templateStr)) !== null) {


          // Push text before the tag


          const text = templateStr.slice(cursor, match.index);


          if (text) fn += '__o.push(' + JSON.stringify(text) + ');\n';


          cursor = re.lastIndex;





          if (match[1] === '=') {


            // Escaped output


            fn += '__o.push(String(' + match[2].trim() + '));\n';


          } else if (match[1] === '-') {


            // Raw output


            fn += '__o.push(' + match[2].trim() + ');\n';


          } else {


            // Code execution


            fn += match[2] + '\n';


          }


        }





        // Push remaining text


        fn += '__o.push(' + JSON.stringify(templateStr.slice(cursor)) + ');\n';


        fn += '}\nreturn __o.join("");';





        try {


          return new Function('data', fn)(data);


        } catch (e) {


          console.error('EJS Render Error:', e);


          return '<p style="color:red;">Template render error</p>';


        }


      }





      // ======= TEMPLATE MAPPING PER ROLE/SECTION =======


      const templateMap = {


        'student-cspc': {


          'overview': 'tmpl-student-cspc-overview',


          'profile': 'tmpl-student-cspc-profile',


          'enrollment': 'tmpl-student-cspc-enrollment',


          'schedule': 'tmpl-student-cspc-schedule',


          'news': 'tmpl-shared-news',


          'buildings': 'tmpl-student-buildings',


        },


        'student-non-cspc': {


          'overview': 'tmpl-student-non-cspc-overview',


          'offices': 'tmpl-student-non-cspc-offices',


          'admission': 'tmpl-student-non-cspc-admission',


          'map': 'tmpl-shared-map',


        },


        'instructor': {


          'overview': 'tmpl-instructor-overview',


          'profile': 'tmpl-instructor-profile',


          'all-rooms': 'tmpl-instructor-all-rooms',
          'schedule': 'tmpl-instructor-schedule',
          'buildings': 'tmpl-instructor-buildings',


          'announcements': 'tmpl-instructor-announcements',


          'status': 'tmpl-instructor-status',


        },


        'admin': {


          'overview': 'tmpl-admin-overview',


          'users': 'tmpl-admin-users',


          'map-data': 'tmpl-admin-map-data',


          'news-editor': 'tmpl-admin-news-editor',


          'logs': 'tmpl-admin-logs',


        },


        'guest': {


          'overview': 'tmpl-guest-overview',


          'offices': 'tmpl-student-non-cspc-offices',


          'admission': 'tmpl-student-non-cspc-admission',


          'corridors': 'tmpl-guest-corridors',


          'news-events': 'tmpl-guest-news-events',


          'achievements': 'tmpl-guest-achievements',


          'map': 'tmpl-shared-map',


        }


      };





      // ======= STATE =======


      let currentRole = 'student-cspc';


      let currentSection = 'overview';





      // ======= DOM REFERENCES =======


      const roleTitle = document.getElementById('roleTitle');


      const roleBadge = document.getElementById('roleBadge');


      const sidebarNav = document.getElementById('sidebarNav');


      const contentContainer = document.getElementById('contentContainer');


      const panelGreeting = document.getElementById('panelGreeting');


      const panelRoleLabel = document.getElementById('panelRoleLabel');


      const sidebarName = document.getElementById('sidebarName');


      const sidebarEmail = document.getElementById('sidebarEmail');


      const navUsername = document.getElementById('navUsername');





      // ======= ICON SVGs =======


      const icons = {


        home: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>',


        user: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',


        book: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',


        calendar: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',


        bell: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>',


        map: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>',


        info: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',


        megaphone: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',


        door: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/></svg>',


        check: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>',


        users: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',


        edit: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',


        file: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',


        phone: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',


      };





      // ======= RENDER SIDEBAR NAV =======


      function renderSidebar(role) {


        const items = CampuSphereData.sidebarNav[role] || [];


        sidebarNav.innerHTML = items.map(item =>


          `<button class="sidebar__nav-item ${item.id === currentSection ? 'sidebar__nav-item--active' : ''}" data-section="${item.id}">


          <span class="sidebar__nav-icon">${icons[item.icon] || ''}</span>


          ${item.label}


        </button>`


        ).join('');





        // Add click handlers


        sidebarNav.querySelectorAll('.sidebar__nav-item').forEach(btn => {


          btn.addEventListener('click', () => switchSection(btn.dataset.section));


        });


      }





      // ======= RENDER CONTENT SECTION =======


      function renderContent(role, section) {


        const map = templateMap[role];


        if (!map) return;





        const templateId = map[section];


        if (!templateId) return;





        const tmplEl = document.getElementById(templateId);


        if (!tmplEl) return;





        const html = ejsRender(tmplEl.textContent, CampuSphereData);


        contentContainer.innerHTML = html;





        // Post-render hooks


        if (role === 'instructor' && section === 'all-rooms') renderAllRoomsAccordion();


        if (role === 'instructor' && section === 'buildings') renderInstructorBuildings();


        if (role === 'student-cspc' && section === 'buildings') renderStudentBuildings();





        // If the template contains a Leaflet map container, initialize it


        const mapEl = document.getElementById('dashLeafletMap');


        if (mapEl) initDashLeaflet(mapEl);


      }





      // ======= ALL ROOMS ACCORDION =======


      function renderAllRoomsAccordion() {


        const container = document.getElementById('allRoomsAccordion');


        if (!container) return;


        const buildings = CampuSphereData.instructorBuildings || [];


        const assignedNames = (CampuSphereData.instructorProfile.assignedRooms || []).map(r => r.room.toLowerCase());





        container.innerHTML = buildings.map((b, idx) => {


          const totalRooms = b.floorData.reduce((sum, f) => sum + f.rooms.length, 0);


          const catColors = { Academic: 'var(--navy-600)', Administrative: '#d4a843', Facilities: '#16a34a' };


          const catColor = catColors[b.category] || 'var(--navy-600)';


          return `


        <div class="instr-accordion" data-idx="${idx}">


          <button class="instr-accordion__toggle" onclick="toggleAccordion(this)">


            <div class="instr-accordion__info">


              <span class="instr-accordion__cat" style="background:${catColor};color:#fff;padding:2px 8px;border-radius:999px;font-size:.65rem;font-weight:700;text-transform:uppercase;">${b.category}</span>


              <strong>${b.name}</strong>


              <span style="font-size:.8rem;color:var(--gray-500);">${totalRooms} rooms · ${b.floors} floor${b.floors > 1 ? 's' : ''}</span>


            </div>


            <svg class="instr-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>


          </button>


          <div class="instr-accordion__body" style="display:none;">


            ${b.floorData.map(floor => `


              <div class="instr-accordion__floor-label">${floor.label}</div>


              <table class="data-table" style="margin-bottom:var(--space-md);">


                <thead><tr><th>Room</th><th>Type</th><th>Capacity</th><th></th></tr></thead>


                <tbody>


                  ${floor.rooms.map(r => {


            const isAssigned = assignedNames.some(a => a.includes(r.num.toLowerCase()));


            return `<tr style="${isAssigned ? 'background:rgba(30,77,140,0.08);' : ''}"><td><strong>${r.num}</strong></td><td>${r.use}</td><td>${r.capacity}</td><td>${isAssigned ? '<span style="color:var(--navy-600);font-weight:700;font-size:.75rem;">★ Assigned</span>' : ''}</td></tr>`;


          }).join('')}


                </tbody>


              </table>


            `).join('')}


          </div>


        </div>`;


        }).join('');


      }





      function toggleAccordion(btn) {


        const body = btn.nextElementSibling;


        const chevron = btn.querySelector('.instr-accordion__chevron');


        const isOpen = body.style.display !== 'none';


        body.style.display = isOpen ? 'none' : 'block';


        chevron.style.transform = isOpen ? '' : 'rotate(180deg)';


      }





      // ======= NAVIGATE BUILDINGS =======


      function renderInstructorBuildings() {


        const grid = document.getElementById('instrBuildingGrid');


        const detail = document.getElementById('instrBuildingDetail');


        if (!grid) return;


        const buildings = CampuSphereData.instructorBuildings || [];


        const catIcons = { Academic: '🏛️', Administrative: '🏢', Facilities: '🏟️' };





        grid.innerHTML = buildings.map(b => `


        <div class="stat-card instr-bldg-card" style="cursor:pointer; display:flex; flex-direction:column; min-height:100%;" data-bid="${b.id}" onclick="showBuildingInside(${b.id})">


          <div class="stat-card__icon stat-card__icon--blue">${catIcons[b.category] || '🏢'}</div>


          <div class="stat-card__label" style="margin-bottom:4px;font-weight:700;">${b.name}</div>


          <p style="font-size:0.78rem;color:var(--gray-500);line-height:1.5;margin:0 0 12px; flex-grow:1;">${b.desc}</p>


          <div style="display:flex;align-items:center;gap:8px;font-size:0.72rem; margin-bottom:8px;">


            <span style="font-weight:600;color:var(--navy-600);">Floors: ${b.floors}</span>


            <span style="color:var(--gray-400);">·</span>


            <span style="color:var(--gray-500);">Rooms: ${b.floorData.reduce((s, f) => s + f.rooms.length, 0)}</span>


          </div>


          <button class="btn btn--primary btn--sm" style="margin-top:auto;width:100%;font-size:.75rem;" onclick="event.stopPropagation();showBuildingInside(${b.id})">View Inside</button>


        </div>


      `).join('');


      }





      function showBuildingInside(id) {


        const detail = document.getElementById('instrBuildingDetail');


        if (!detail) return;


        const b = CampuSphereData.instructorBuildings.find(x => x.id === id);


        if (!b) return;


        const assignedNames = (CampuSphereData.instructorProfile.assignedRooms || []).map(r => r.room.toLowerCase());





        detail.style.display = 'block';


        detail.innerHTML = `


        <div class="panel-card">


          <div class="panel-card__header">


            <h3 class="panel-card__title">${b.name} — Room Layout</h3>


            <button class="btn btn--outline btn--sm" onclick="document.getElementById('instrBuildingDetail').style.display='none'">✖ Close</button>


          </div>


          <div class="panel-card__body">


            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:var(--space-md);">


              ${b.floorData.map((f, i) => `<button class="btn btn--sm ${i === 0 ? 'btn--primary' : 'btn--outline'}" onclick="showFloorInside(${id},${i},this)" style="font-size:.75rem;">${f.label}</button>`).join('')}


            </div>


            <div id="instrFloorContent">


              ${renderFloorInside(b, 0, assignedNames)}


            </div>


          </div>


        </div>


      `;


        detail.scrollIntoView({ behavior: 'smooth', block: 'start' });


      }





      function showFloorInside(bid, fi, btn) {


        const b = CampuSphereData.instructorBuildings.find(x => x.id === bid);


        if (!b) return;


        const assignedNames = (CampuSphereData.instructorProfile.assignedRooms || []).map(r => r.room.toLowerCase());


        document.getElementById('instrFloorContent').innerHTML = renderFloorInside(b, fi, assignedNames);


        // Update active button


        btn.parentElement.querySelectorAll('.btn').forEach(bt => { bt.classList.remove('btn--primary'); bt.classList.add('btn--outline'); });


        btn.classList.add('btn--primary'); btn.classList.remove('btn--outline');


      }





      function renderFloorInside(b, fi, assignedNames) {


        const floor = b.floorData[fi];


        return `


        <h4 style="font-size:.9rem;margin:0 0 var(--space-sm);color:var(--navy-700);">${floor.label}</h4>


        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">


          ${floor.rooms.map(r => {


          const isAssigned = assignedNames.some(a => a.includes(r.num.toLowerCase()));


          return `<div style="padding:12px 14px;border-radius:var(--radius-md);border:1.5px solid ${isAssigned ? 'var(--navy-600)' : 'var(--gray-200)'};background:${isAssigned ? 'rgba(30,77,140,0.06)' : 'var(--white)'};transition:border-color .2s;">


              <div style="font-weight:700;font-size:.85rem;color:var(--navy-800);">${r.num} ${isAssigned ? '<span style="color:var(--navy-600);font-size:.7rem;">★</span>' : ''}</div>


              <div style="font-size:.78rem;color:var(--gray-500);margin-top:2px;">${r.use}</div>


              <div style="font-size:.72rem;color:var(--gray-400);margin-top:4px;">Capacity: ${r.capacity}</div>


            </div>`;


        }).join('')}


        </div>


      `;


      }





      // ======= NAVIGATE BUILDINGS: Student =======


      function renderStudentBuildings() {


        const grid = document.getElementById('studentBuildingGrid');


        if (!grid) return;


        const buildings = CampuSphereData.instructorBuildings || [];


        const catIcons = { Academic: '🏛️', Administrative: '🏢', Facilities: '🏟️' };





        grid.innerHTML = buildings.map(b => `


        <div class="stat-card instr-bldg-card" style="cursor:pointer; display:flex; flex-direction:column; min-height:100%;" data-bid="${b.id}" onclick="showStudentBuildingInside(${b.id})">


          <div class="stat-card__icon stat-card__icon--blue">${catIcons[b.category] || '🏢'}</div>


          <div class="stat-card__label" style="margin-bottom:4px;font-weight:700;">${b.name}</div>


          <p style="font-size:0.78rem;color:var(--gray-500);line-height:1.5;margin:0 0 12px; flex-grow:1;">${b.desc}</p>


          <div style="display:flex;align-items:center;gap:8px;font-size:0.72rem; margin-bottom:8px;">


            <span style="font-weight:600;color:var(--navy-600);">Floors: ${b.floors}</span>


            <span style="color:var(--gray-400);">·</span>


            <span style="color:var(--gray-500);">Rooms: ${b.floorData.reduce((s, f) => s + f.rooms.length, 0)}</span>


          </div>


          <button class="btn btn--primary btn--sm" style="margin-top:auto;width:100%;font-size:.75rem;" onclick="event.stopPropagation();showStudentBuildingInside(${b.id})">View Inside</button>


        </div>


      `).join('');


      }





      function showStudentBuildingInside(id) {


        const detail = document.getElementById('studentBuildingDetail');


        if (!detail) return;


        const b = CampuSphereData.instructorBuildings.find(x => x.id === id);


        if (!b) return;


        const scheduledNames = (CampuSphereData.schedule || []).map(r => r.room.toLowerCase());





        detail.style.display = 'block';


        detail.innerHTML = `


        <div class="panel-card">


          <div class="panel-card__header">


            <h3 class="panel-card__title">${b.name} — Room Layout</h3>


            <button class="btn btn--outline btn--sm" onclick="document.getElementById('studentBuildingDetail').style.display='none'">✖ Close</button>


          </div>


          <div class="panel-card__body">


            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:var(--space-md);">


              ${b.floorData.map((f, i) => `<button class="btn btn--sm ${i === 0 ? 'btn--primary' : 'btn--outline'}" onclick="showStudentFloorInside(${id},${i},this)" style="font-size:.75rem;">${f.label}</button>`).join('')}


            </div>


            <div id="studentFloorContent">


              ${renderStudentFloorInside(b, 0, scheduledNames)}


            </div>


          </div>


        </div>


      `;


        detail.scrollIntoView({ behavior: 'smooth', block: 'start' });


      }





      function showStudentFloorInside(bid, fi, btn) {


        const b = CampuSphereData.instructorBuildings.find(x => x.id === bid);


        if (!b) return;


        const scheduledNames = (CampuSphereData.schedule || []).map(r => r.room.toLowerCase());


        document.getElementById('studentFloorContent').innerHTML = renderStudentFloorInside(b, fi, scheduledNames);


        // Update active button


        btn.parentElement.querySelectorAll('.btn').forEach(bt => { bt.classList.remove('btn--primary'); bt.classList.add('btn--outline'); });


        btn.classList.add('btn--primary'); btn.classList.remove('btn--outline');


      }





      function renderStudentFloorInside(b, fi, scheduledNames) {


        const floor = b.floorData[fi];


        return `


        <h4 style="font-size:.9rem;margin:0 0 var(--space-sm);color:var(--navy-700);">${floor.label}</h4>


        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">


          ${floor.rooms.map(r => {


          const isScheduled = scheduledNames.some(a => a.includes(r.num.toLowerCase()));


          return `<div style="padding:12px 14px;border-radius:var(--radius-md);border:1.5px solid ${isScheduled ? 'var(--navy-600)' : 'var(--gray-200)'};background:${isScheduled ? 'rgba(30,77,140,0.06)' : 'var(--white)'};transition:border-color .2s;">


              <div style="font-weight:700;font-size:.85rem;color:var(--navy-800);">${r.num} ${isScheduled ? '<span style="color:var(--navy-600);font-size:.7rem;">★</span>' : ''}</div>


              <div style="font-size:.78rem;color:var(--gray-500);margin-top:2px;">${r.use}</div>


              <div style="font-size:.72rem;color:var(--gray-400);margin-top:4px;">Capacity: ${r.capacity}</div>


            </div>`;


        }).join('')}


        </div>


      `;


      }





      // ======= SWITCH SECTION =======


      function switchSection(sectionId) {


        currentSection = sectionId;


        renderSidebar(currentRole);


        renderContent(currentRole, currentSection);





        // Close sidebar on mobile


        document.getElementById('sidebar').classList.remove('open');


      }





      // Expose to window for profile-script.js re-render


      window.switchSection = switchSection;


      window.switchRole = switchRole;


      Object.defineProperty(window, 'currentRole', { get() { return currentRole; }, set(v) { currentRole = v; } });


      Object.defineProperty(window, 'currentSection', { get() { return currentSection; }, set(v) { currentSection = v; } });





      // ======= SWITCH ROLE =======


      function switchRole(role) {


        currentRole = role;


        currentSection = 'overview';


        const roleInfo = CampuSphereData.roles[role];





        // Update role title and badge


        roleTitle.textContent = roleInfo.label;


        roleBadge.textContent = roleInfo.badge;


        roleBadge.style.background = roleInfo.color;





        // Update panel header — read from CampuSphereData profiles (already merged with localStorage)


        let displayName = 'User';


        let displayFullName = 'User';


        let displayEmail = '';





        if (role === 'student-cspc' && CampuSphereData.studentProfile) {


          displayFullName = CampuSphereData.studentProfile.name || 'Aaron V. Lasprillas';


          displayName = displayFullName.split(' ')[0];


          displayEmail = CampuSphereData.studentProfile.email || 'aaron@cspc.edu.ph';


        } else if (role === 'instructor' && CampuSphereData.instructorProfile) {


          displayFullName = CampuSphereData.instructorProfile.name || 'Dr. Maria Santos';


          displayName = displayFullName.split(' ')[0];


          displayEmail = CampuSphereData.instructorProfile.email || 'maria.santos@cspc.edu.ph';


        } else if (role === 'student-non-cspc') {


          displayName = 'Student';


          displayFullName = 'Guest Student';


          displayEmail = 'student@gmail.com';


        } else if (role === 'admin') {


          displayName = 'Admin';


          displayFullName = 'System Administrator';


          displayEmail = 'admin@cspc.edu.ph';


        } else {


          displayName = 'Guest';


          displayFullName = 'Guest User';


          displayEmail = 'guest@gmail.com';


        }





        panelGreeting.textContent = `Welcome, ${displayName} !`;


        panelRoleLabel.textContent = `${roleInfo.label} — ${roleInfo.badge}`;


        navUsername.textContent = displayName;





        // Update sidebar user


        sidebarName.textContent = displayFullName;


        sidebarEmail.textContent = displayEmail;





        renderSidebar(role);


        renderContent(role, 'overview');


      }





      // ======= DASHBOARD LEAFLET MAP =======


      function initDashLeaflet(container) {


        const map = L.map(container).setView([13.40591, 123.37362], 17);


        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {


          attribution: '&copy; OpenStreetMap contributors'


        }).addTo(map);





        const buildings = CampuSphereData.buildings || [];


        buildings.forEach(b => {


          if (b.lat && b.lng) {


            L.marker([b.lat, b.lng]).addTo(map).bindTooltip(b.name);


          }


        });





        // Fix Leaflet tile rendering in dynamically injected containers


        setTimeout(() => map.invalidateSize(), 200);


      }





      // ======= EVENT LISTENERS =======





      // Navbar scroll


      const dashNav = document.getElementById('dashNav');


      window.addEventListener('scroll', () => dashNav.classList.toggle('scrolled', window.scrollY > 10));





      // Mobile hamburger


      const dashHamburger = document.getElementById('dashHamburger');


      const dashTabs = document.getElementById('dashTabs');


      dashHamburger.addEventListener('click', () => {


        dashHamburger.classList.toggle('active');


        dashTabs.classList.toggle('open');


      });





      // Sidebar mobile toggle


      const sidebarToggle = document.getElementById('sidebarToggle');


      const sidebar = document.getElementById('sidebar');


      sidebarToggle.addEventListener('click', () => sidebar.classList.toggle('open'));





      // Close sidebar on outside click (mobile)


      document.addEventListener('click', (e) => {


        if (window.innerWidth <= 900 && !sidebar.contains(e.target) && e.target !== sidebarToggle && !sidebarToggle.contains(e.target)) {


          sidebar.classList.remove('open');


        }


      });





      // ======= INIT =======


      const savedRole = localStorage.getItem('campusphere-role') || 'student-cspc';


      switchRole(savedRole);





      // ======= THEME TOGGLE =======


      (function () {


        const toggle = document.getElementById('themeToggle');


        const saved = localStorage.getItem('campussphere-theme');


        if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');


        toggle.addEventListener('click', () => {


          const isDark = document.documentElement.getAttribute('data-theme') === 'dark';


          if (isDark) { document.documentElement.removeAttribute('data-theme'); localStorage.setItem('campussphere-theme', 'light'); }


          else { document.documentElement.setAttribute('data-theme', 'dark'); localStorage.setItem('campussphere-theme', 'dark'); }


        });


      })();


    </script>


    <!-- Edit Profile Script -->


    <script src="/js/profile-script.js"></script>
    <script src="/js/nav-role.js"></script>


</body>





</html>