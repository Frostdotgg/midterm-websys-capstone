                        </div>

                        <!-- Recent News -->
                        <div class="ui-card border-border">
                            <div class="p-6 pb-3" style="border-bottom:none;">
                                <h3 class="text-lg font-semibold tracking-tight text-foreground">Recent News</h3>
                            </div>
                            <div class="p-6 pt-0" style="display:flex; flex-direction:column; gap:1rem;">
                                <div class="rounded-lg border border-border p-4 transition-colors hover:bg-muted/50">
