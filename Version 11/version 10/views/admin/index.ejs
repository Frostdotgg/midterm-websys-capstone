                                    <p class="text-sm text-muted-foreground">Monthly active users and map interactions
                                    </p>
                                </div>
                                <div class="p-6 pt-0">
                                    <canvas id="activityChart" style="width:100%; height:300px;"></canvas>
                                    <div class="mt-4 flex items-center justify-center gap-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-3 w-3 rounded-full" style="background:var(--navy-600);"></div>
                                            <span class="text-sm text-muted-foreground">Users</span>
                                        </div>
                                        <div class="flex items-center gap-2">
