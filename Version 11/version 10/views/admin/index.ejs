    <script>
        lucide.createIcons();

        // ── Activity Chart (Canvas area chart) ──
        (function () {
            const canvas = document.getElementById('activityChart');
            if (!canvas) return;
            const dpr = window.devicePixelRatio || 1;
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * dpr;
            canvas.height = 300 * dpr;
            canvas.style.height = '300px';
            const ctx = canvas.getContext('2d');
            ctx.scale(dpr, dpr);
            const W = rect.width, H = 300;
            const pad = { top: 20, right: 20, bottom: 30, left: 50 };
            const data = [
                { date: 'Jan', users: 400, mapViews: 2400 },
                { date: 'Feb', users: 300, mapViews: 1398 },
                { date: 'Mar', users: 520, mapViews: 3800 },
                { date: 'Apr', users: 478, mapViews: 3908 },
                { date: 'May', users: 589, mapViews: 4800 },
                { date: 'Jun', users: 639, mapViews: 3800 },
                { date: 'Jul', users: 780, mapViews: 4300 },
                { date: 'Aug', users: 890, mapViews: 5100 },
                { date: 'Sep', users: 720, mapViews: 4200 },
                { date: 'Oct', users: 850, mapViews: 5500 },
                { date: 'Nov', users: 920, mapViews: 6100 },
                { date: 'Dec', users: 1100, mapViews: 7200 }
            ];
            const maxVal = 7200;
            const cW = W - pad.left - pad.right;
            const cH = H - pad.top - pad.bottom;
            const xStep = cW / (data.length - 1);

            function yPos(v) { return pad.top + cH - (v / maxVal) * cH; }
            function xPos(i) { return pad.left + i * xStep; }

            // Grid lines
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
            ctx.lineWidth = 1;
            for (let i = 0; i <= 5; i++) {
                const y = pad.top + (cH / 5) * i;
                ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
            }

            // Y-axis labels
            ctx.fillStyle = isDark ? '#9ca3af' : '#6b7280';
            ctx.font = '12px Inter, system-ui, sans-serif';
            ctx.textAlign = 'right';
            for (let i = 0; i <= 5; i++) {
                const val = Math.round((maxVal / 5) * (5 - i));
                const y = pad.top + (cH / 5) * i;
                ctx.fillText(val.toLocaleString(), pad.left - 8, y + 4);
            }

            // X-axis labels
            ctx.textAlign = 'center';
            data.forEach((d, i) => {
                ctx.fillText(d.date, xPos(i), H - 8);
            });

            // Draw filled area + line helper
            function drawArea(key, strokeColor, fillColorTop, fillColorBot) {
                const grad = ctx.createLinearGradient(0, pad.top, 0, H - pad.bottom);
                grad.addColorStop(0, fillColorTop);
                grad.addColorStop(1, fillColorBot);
                ctx.beginPath();
                ctx.moveTo(xPos(0), yPos(data[0][key]));
                for (let i = 1; i < data.length; i++) {
                    const cx1 = xPos(i - 1) + xStep * 0.4;
                    const cx2 = xPos(i) - xStep * 0.4;
                    ctx.bezierCurveTo(cx1, yPos(data[i - 1][key]), cx2, yPos(data[i][key]), xPos(i), yPos(data[i][key]));
                }
                ctx.lineTo(xPos(data.length - 1), H - pad.bottom);
                ctx.lineTo(xPos(0), H - pad.bottom);
                ctx.closePath();
                ctx.fillStyle = grad;
                ctx.fill();
                ctx.beginPath();
                ctx.moveTo(xPos(0), yPos(data[0][key]));
                for (let i = 1; i < data.length; i++) {
                    const cx1 = xPos(i - 1) + xStep * 0.4;
                    const cx2 = xPos(i) - xStep * 0.4;
                    ctx.bezierCurveTo(cx1, yPos(data[i - 1][key]), cx2, yPos(data[i][key]), xPos(i), yPos(data[i][key]));
                }
                ctx.strokeStyle = strokeColor;
                ctx.lineWidth = 2;
                ctx.stroke();
            }

            drawArea('mapViews', '#d4a843', 'rgba(212,168,67,0.3)', 'rgba(212,168,67,0)');
            drawArea('users', '#1a3a6b', 'rgba(26,58,107,0.3)', 'rgba(26,58,107,0)');
        })();

        // ── Role Distribution (SVG donut chart) ──
        (function () {
            const svg = document.getElementById('roleChart');
            if (!svg) return;
            const roles = [
                { value: 1845, color: '#1a3a6b' },
                { value: 389, color: '#2563a8' },
                { value: 156, color: '#d4a843' },
                { value: 24, color: '#7c3aed' },
                { value: 433, color: '#6b7280' }
            ];
            const total = roles.reduce((s, r) => s + r.value, 0);
            const cx = 100, cy = 100, outerR = 80, innerR = 50, gap = 2;
            let startAngle = -Math.PI / 2;
            roles.forEach(r => {
                const sliceAngle = (r.value / total) * Math.PI * 2;
                const gapAngle = gap / outerR;
                const a1 = startAngle + gapAngle / 2;
                const a2 = startAngle + sliceAngle - gapAngle / 2;
                const x1o = cx + outerR * Math.cos(a1);
                const y1o = cy + outerR * Math.sin(a1);
                const x2o = cx + outerR * Math.cos(a2);
                const y2o = cy + outerR * Math.sin(a2);
                const x2i = cx + innerR * Math.cos(a2);
                const y2i = cy + innerR * Math.sin(a2);
                const x1i = cx + innerR * Math.cos(a1);
                const y1i = cy + innerR * Math.sin(a1);
                const large = sliceAngle > Math.PI ? 1 : 0;
                const d = `M ${x1o} ${y1o} A ${outerR} ${outerR} 0 ${large} 1 ${x2o} ${y2o} L ${x2i} ${y2i} A ${innerR} ${innerR} 0 ${large} 0 ${x1i} ${y1i} Z`;
                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('d', d);
                path.setAttribute('fill', r.color);
                svg.appendChild(path);
                startAngle += sliceAngle;
            });
        })();
    </script>
