                                            <span class="text-sm text-muted-foreground">Map Views</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="ui-card border-border h-full">
                                <div class="p-6 pb-2" style="border-bottom:none;">
                                    <h3 class="text-lg font-semibold tracking-tight text-foreground">User Roles
                                        Distribution</h3>
                                    <p class="text-sm text-muted-foreground">Breakdown by role type</p>
                                </div>
                                <div class="p-6 pt-0">
                                    <div class="flex items-center justify-center" style="height:200px;">
                                        <svg id="roleChart" viewBox="0 0 200 200" width="180" height="180"></svg>
                                    </div>
                                    <div class="mt-4" style="display:flex; flex-direction:column; gap:0.5rem;">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <div class="h-3 w-3 rounded-full" style="background:#1a3a6b;"></div>
                                                <span class="text-sm text-muted-foreground">Students (CSPC)</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-medium text-foreground">1,845</span>
                                                <span class="text-xs text-muted-foreground">(64.8%)</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <div class="h-3 w-3 rounded-full" style="background:#2563a8;"></div>
                                                <span class="text-sm text-muted-foreground">Students (Guest)</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-medium text-foreground">389</span>
                                                <span class="text-xs text-muted-foreground">(13.7%)</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <div class="h-3 w-3 rounded-full" style="background:#d4a843;"></div>
                                                <span class="text-sm text-muted-foreground">Instructors</span>
