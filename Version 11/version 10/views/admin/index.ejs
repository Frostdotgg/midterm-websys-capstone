                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-medium text-foreground">433</span>
                                                <span class="text-xs text-muted-foreground">(15.2%)</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="ui-card border-border">
                        <div class="p-6 pb-3" style="border-bottom:none;">
                            <h3 class="text-lg font-semibold tracking-tight text-foreground">Quick Actions</h3>
                        </div>
                        <div class="p-6 pt-0">
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                                <button
                                    class="ui-button ui-button-default h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="user-plus" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">Add User</p>
                                        <p class="text-xs font-normal"
                                            style="color:var(--primary-foreground); opacity:0.8;">Register new student
                                            or instructor</p>
                                    </div>
                                </button>
                                <button
                                    class="ui-button ui-button-outline h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="newspaper" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">Post News</p>
                                        <p class="text-xs text-muted-foreground font-normal">Create announcement</p>
                                    </div>
                                </button>
                                <button
                                    class="ui-button ui-button-outline h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="help-circle" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">Add FAQ</p>
                                        <p class="text-xs text-muted-foreground font-normal">Add new question</p>
                                    </div>
                                </button>
                                <button
                                    class="ui-button ui-button-outline h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="map" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">Update Map</p>
                                        <p class="text-xs text-muted-foreground font-normal">Modify campus map</p>
                                    </div>
                                </button>
                                <button
                                    class="ui-button ui-button-outline h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="file-text" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">View Logs</p>
                                        <p class="text-xs text-muted-foreground font-normal">Check system activity</p>
                                    </div>
                                </button>
                                <button
                                    class="ui-button ui-button-outline h-auto flex-col items-start gap-2 p-4 text-left">
                                    <i data-lucide="settings" class="h-5 w-5"></i>
                                    <div>
                                        <p class="text-sm font-medium">Settings</p>
                                        <p class="text-xs text-muted-foreground font-normal">Configure portal</p>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Content Row (Users & News) -->
                    <div class="grid gap-6 lg:grid-cols-2">
