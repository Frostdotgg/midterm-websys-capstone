                                </div>
                                <div class="mt-4">
                                    <h3 class="text-2xl font-bold text-foreground">12.4K</h3>
                                    <p class="text-sm font-medium text-foreground/80">Map Views</p>
                                    <p class="mt-1 text-xs text-muted-foreground">Campus map interactions</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="grid gap-6 lg:grid-cols-3">
                        <div class="lg:col-span-2">
