                            </div>
                        </div>

                        <div class="ui-card border-border">
                            <div class="p-6">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-primary/10 p-2.5">
                                        <i data-lucide="newspaper" class="h-5 w-5 text-primary"></i>
                                    </div>
                                    <div class="flex items-center gap-1 text-xs font-medium text-chart-1">
                                        <i data-lucide="trending-up" class="h-3 w-3"></i>+23.1%
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <h3 class="text-2xl font-bold text-foreground">156</h3>
                                    <p class="text-sm font-medium text-foreground/80">News Articles</p>
                                    <p class="mt-1 text-xs text-muted-foreground">Published this month</p>
                                </div>
                            </div>
                        </div>

                        <div class="ui-card border-border">
                            <div class="p-6">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-primary/10 p-2.5">
