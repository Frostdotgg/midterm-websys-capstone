                                    <p class="text-sm font-medium text-foreground/80">Total Users</p>
                                    <p class="mt-1 text-xs text-muted-foreground">Active users this month</p>
                                </div>
                            </div>
                        </div>

                        <div class="ui-card border-border">
                            <div class="p-6">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-primary/10 p-2.5">
                                        <i data-lucide="graduation-cap" class="h-5 w-5 text-primary"></i>
                                    </div>
                                    <div class="flex items-center gap-1 text-xs font-medium text-chart-1">
