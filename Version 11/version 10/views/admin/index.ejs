                                                <span class="text-xs text-muted-foreground">(0.8%)</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <div class="h-3 w-3 rounded-full" style="background:#6b7280;"></div>
