<!DOCTYPE html>
<html lang="en">

<head>
    <script>
        (function () {
            var savedTheme = localStorage.getItem('adminTheme') || localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.write('<style>html[data-theme="dark"], html[data-theme="dark"] body { background-color: #111827 !important; color: #e5e7eb !important; }</style>');
            }
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampuSphere Admin Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Lucide Icons -> load via CDN for easy vanilla implementation -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/js/admin/main.js" defer></script>
</head>

<body class="font-sans antialiased">
    <div class="flex h-screen bg-background text-foreground overflow-hidden">

        <!-- Sidebar -->
        <aside id="sidebar"
            class="relative flex h-screen flex-col bg-sidebar text-sidebar-foreground border-r border-sidebar-border transition-all duration-300 w-64 shrink-0">
            <!-- Header -->
            <div class="flex items-center gap-3 px-4 py-5 border-b border-sidebar-border h-16">
                <img src="/img/cspc-logo.png" alt="CSPC Logo" class="sidebar-logo shrink-0">
                <div id="sidebar-header-full" class="flex flex-col">
                    <span class="sidebar-brand-title">Campu<span>Sphere</span></span>
                    <span class="sidebar-brand-sub">Admin Portal</span>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-2 py-4 overflow-y-auto" style="display:flex; flex-direction:column; gap:2px;">
                <a href="/admin"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors bg-sidebar-accent text-sidebar-accent-foreground mt-1">
                    <i data-lucide="layout-dashboard" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                <a href="/admin/users"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="users" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">Users</span>
                </a>
                <a href="/admin/news"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="newspaper" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">News</span>
                </a>
                <a href="/admin/faqs"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="help-circle" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">FAQs</span>
                </a>
                <a href="/admin/logs"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="file-text" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">System Logs</span>
                </a>
                <a href="/admin/campus-map"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="map" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">Campus Map</span>
                </a>
                <a href="/admin/settings"
                    class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground mt-1">
                    <i data-lucide="settings" class="h-5 w-5 shrink-0"></i>
                    <span class="sidebar-text">Settings</span>
                </a>
            </nav>

            <!-- User section -->
            <div class="border-t border-sidebar-border p-4">
                <div class="flex items-center gap-3">
                    <div class="ui-avatar h-9 w-9 shrink-0">
                        <div class="ui-avatar-fallback text-xs font-semibold">AD</div>
                    </div>
                    <div id="sidebar-user-full" class="flex flex-col flex-1 min-w-0">
                        <span class="text-sm font-medium truncate">Admin User</span>
                        <span class="text-xs text-sidebar-foreground/60 truncate">admin@cspc.edu.ph</span>
                    </div>
                    <button
                        class="ui-button ui-button-ghost ui-button-size-icon h-8 w-8 text-sidebar-foreground/70 shrink-0 sidebar-text">
                        <i data-lucide="log-out" class="h-4 w-4"></i>
                    </button>
                </div>
            </div>

            <!-- Collapse button -->
            <button id="sidebar-toggle"
                class="ui-button ui-button-ghost ui-button-size-icon absolute -right-3 top-7 h-6 w-6 rounded-full border border-sidebar-border bg-sidebar text-sidebar-foreground hover:bg-sidebar-accent"
                style="width:1.5rem; height:1.5rem; padding:0;">
                <i id="sidebar-icon-left" data-lucide="chevron-left" class="h-3 w-3"></i>
                <i id="sidebar-icon-right" data-lucide="chevron-right" class="h-3 w-3 hidden"></i>
            </button>
        </aside>

        <!-- Main Content Area -->
        <div class="flex flex-1 flex-col overflow-hidden">
            <!-- Header -->
            <header class="flex h-16 items-center justify-between border-b border-border bg-card px-6 shrink-0">
                <div>
                    <h1 class="text-xl font-semibold text-foreground">Dashboard</h1>
                    <p class="text-sm text-muted-foreground">Welcome back, Admin. Here's what's happening with
                        CampusSphere.</p>
                </div>

                <div class="flex items-center gap-4">
                    <!-- Search -->
                    <div class="relative hidden md:block">
                        <i data-lucide="search"
                            class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"></i>
                        <input type="search" placeholder="Search..."
                            class="ui-input w-64 pl-9 bg-secondary/50 border-border">
                    </div>

                    <!-- Notifications Dropdown -->
                    <button class="ui-button ui-button-ghost ui-button-size-icon relative dropdown-trigger"
                        data-dropdown-target="notifications-menu">
                        <i data-lucide="bell" class="h-5 w-5"></i>
                        <span
                            class="ui-badge ui-badge-default absolute -right-1 -top-1 h-5 w-5 rounded-full p-0 flex items-center justify-center text-xs"
                            style="padding:0; min-width:1.25rem;">3</span>
                    </button>

                    <div id="notifications-menu" class="dropdown-menu-content w-80 p-1"
                        style="min-width: 20rem; right: 1.5rem;">
                        <div class="px-2 py-1.5 text-sm font-semibold">Notifications</div>
                        <div class="h-px bg-border my-1" style="margin:0.25rem 0;"></div>

                        <div class="dropdown-menu-item flex flex-col items-start gap-1 p-3">
                            <span class="font-medium text-foreground">New user registration</span>
                            <span class="text-xs text-muted-foreground">John Doe registered as a student</span>
                            <span class="text-xs text-muted-foreground">2 min ago</span>
                        </div>
                        <div class="dropdown-menu-item flex flex-col items-start gap-1 p-3">
                            <span class="font-medium text-foreground">System update available</span>
                            <span class="text-xs text-muted-foreground">Version 1.2.0 is ready to install</span>
                            <span class="text-xs text-muted-foreground">1 hour ago</span>
                        </div>
                        <div class="dropdown-menu-item flex flex-col items-start gap-1 p-3">
                            <span class="font-medium text-foreground">New FAQ submission</span>
                            <span class="text-xs text-muted-foreground">A user submitted a new question</span>
                            <span class="text-xs text-muted-foreground">3 hours ago</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Scrollable Content -->
            <main class="flex-1 overflow-y-auto p-6" style="padding-bottom: 2rem;">
