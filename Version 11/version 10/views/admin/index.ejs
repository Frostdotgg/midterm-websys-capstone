                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-foreground">Carl Ryan P. Lagrimas</p>
                                            <p class="text-xs text-muted-foreground">carl.lagrimas@cspc.edu.ph</p>
                                        </div>
                                    </div>
                                    <span
                                        class="ui-badge ui-badge-outline bg-chart-1/10 text-chart-1 border-chart-1/20">Student</span>
                                </div>
                                <div
                                    class="flex items-center justify-between rounded-lg p-3 transition-colors hover:bg-muted/50">
