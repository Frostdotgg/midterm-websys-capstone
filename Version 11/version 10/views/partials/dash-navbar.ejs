<% var currentTab = typeof activeTab !== 'undefined' ? activeTab : ''; %>
<nav class="dash-nav" id="dashNav">
    <div class="dash-nav__inner">
        <!-- Brand -->
        <a href="/home" class="dash-nav__brand">
            <img src="/img/cspc-logo.png" alt="CSPC Logo" class="dash-nav__logo">
            <span class="dash-nav__title">CampusSphere</span>
        </a>

        <!-- Navigation Tabs -->
        <div class="dash-nav__tabs" id="dashTabs">
            <a href="/home" class="dash-nav__tab<%= currentTab === 'tabHome' ? ' dash-nav__tab--active' : '' %>" id="tabHome">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                </svg>
                <span>Home</span>
            </a>
            <a href="/dashboard" class="dash-nav__tab<%= currentTab === 'tabDashboard' ? ' dash-nav__tab--active' : '' %>" id="tabDashboard">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
                <span>Dashboard</span>
            </a>
            <a href="/buildings" class="dash-nav__tab<%= currentTab === 'tabBuildings' ? ' dash-nav__tab--active' : '' %>" id="tabBuildings">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
                    <path d="M9 22v-4h6v4" />
                    <path d="M8 6h.01" />
                    <path d="M16 6h.01" />
                    <path d="M12 6h.01" />
                    <path d="M12 10h.01" />
                    <path d="M12 14h.01" />
                    <path d="M16 10h.01" />
                    <path d="M16 14h.01" />
                    <path d="M8 10h.01" />
                    <path d="M8 14h.01" />
                </svg>
                <span>Buildings</span>
            </a>
            <a href="/events" class="dash-nav__tab<%= currentTab === 'tabEvents' ? ' dash-nav__tab--active' : '' %>" id="tabEvents">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <span>Events</span>
            </a>
            <a href="/map" class="dash-nav__tab<%= currentTab === 'tabMap' ? ' dash-nav__tab--active' : '' %>" id="tabMap">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                    <line x1="8" y1="2" x2="8" y2="18" />
                    <line x1="16" y1="6" x2="16" y2="22" />
                </svg>
                <span>Campus Map</span>
            </a>
            <a href="/about" class="dash-nav__tab<%= currentTab === 'tabAbout' ? ' dash-nav__tab--active' : '' %>" id="tabAbout">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="16" x2="12" y2="12" />
                    <line x1="12" y1="8" x2="12.01" y2="8" />
                </svg>
                <span>About Us</span>
            </a>
        </div>

        <!-- Right: Notification + User -->
        <div class="dash-nav__right">
            <button class="dash-nav__icon-btn" id="notifBtn" aria-label="Notifications">
                <iconify-icon icon="ep:bell" width="20"></iconify-icon>
                <span class="dash-nav__notif-dot"></span>
            </button>
            <div class="dash-nav__user" id="userMenu">
                <div class="dash-nav__avatar">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
                <span class="dash-nav__username" id="navUsername">Aaron</span>
                <iconify-icon icon="ep:arrow-down" width="14" class="dash-nav__chevron"></iconify-icon>
            </div>
        </div>

        <!-- Mobile Hamburger -->
        <button class="dash-nav__hamburger" id="dashHamburger" aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>
