<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
</head>

<body>
    <div class="auth-page page-transition">
        <div class="auth-card reveal">
            <img src="/img/cspc-logo.png" alt="CSPC Logo" class="auth-logo">
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to your CampusSphere account</p>

            <div style="margin-bottom: var(--space-lg); text-align: left;">
                <label for="loginRole"
                    style="display:block; font-size:0.82rem; font-weight:600; color:var(--gray-600); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em;">Sign in as</label>
                <select id="loginRole"
                    style="width:100%; padding:0.6rem 0.8rem; font-family:var(--font-body); font-size:0.9rem; font-weight:500; color:var(--gray-800); background:var(--gray-50); border:1px solid var(--gray-200); border-radius:var(--radius-md); outline:none; cursor:pointer;">
                    <option value="student-cspc">Student (CSPC)</option>
                    <option value="student-non-cspc">Student (Non-CSPC)</option>
                    <option value="instructor">Instructor</option>
                    <option value="guest">Guest</option>
                    <option value="admin">Admin</option>
                </select>
            </div>

            <button type="button" class="btn btn--primary" style="width: 100%; justify-content: center;"
                onclick="simulateGoogleLogin()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;">
                    <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12s4.477 10 10 10 10-4.477 10-10z"></path>
                    <path d="M12 8v4l3 3"></path>
                </svg>
                Sign in with Google
            </button>

            <div class="auth-footer">
                Don't have an account? <a href="/auth#register" class="auth-link">Register here</a>
            </div>
            <div class="auth-footer" style="margin-top: 10px;">
                <a href="/" class="auth-link" style="color: var(--gray-600); font-size: 0.85rem;">&larr; Back to Home</a>
            </div>
        </div>
    </div>

    <%- include('partials/theme-toggle') %>

    <script>
        function simulateGoogleLogin() {
            const selectedRole = document.getElementById('loginRole').value;
            localStorage.setItem('campusphere-role', selectedRole);
            const btn = document.querySelector('.btn--primary');
            btn.innerHTML = `<svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px; animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> Authenticating...`;
            setTimeout(() => { window.location.href = selectedRole === 'admin' ? '/admin' : '/dashboard'; }, 800);
        }
        const style = document.createElement('style');
        style.textContent = `@keyframes spin { 100% { transform: rotate(360deg); } }`;
        document.head.appendChild(style);
    </script>
</body>

</html>
