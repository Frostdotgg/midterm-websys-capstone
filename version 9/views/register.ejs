<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
</head>

<body>
    <div class="auth-page">
        <div class="auth-card reveal">
            <div class="auth-header">
                <img src="/img/cspc-logo.png" alt="CSPC Logo" class="auth-logo">
                <h1 class="auth-title">Create Account</h1>
                <p class="auth-subtitle">Select your role to join CampusSphere</p>
            </div>

            <form id="registerForm" onsubmit="event.preventDefault(); simulateGoogleLogin();">
                <div class="role-grid">
                    <div class="role-card selected" onclick="selectRole('student-cspc', this)">
                        <span class="role-icon">🧑‍🎓</span>
                        <span class="role-label">Student (CSPC)</span>
                    </div>
                    <div class="role-card" onclick="selectRole('student-non-cspc', this)">
                        <span class="role-icon">📱</span>
                        <span class="role-label">Student (Non-CSPC)</span>
                    </div>
                    <div class="role-card" onclick="selectRole('instructor', this)">
                        <span class="role-icon">👨‍🏫</span>
                        <span class="role-label">Instructor</span>
                    </div>
                    <div class="role-card" onclick="selectRole('guest', this)">
                        <span class="role-icon">👤</span>
                        <span class="role-label">Guest</span>
                    </div>
                </div>

                <input type="hidden" id="selectedRoleInput" name="role" value="student-cspc">

                <button type="button" class="btn btn--primary" style="width: 100%; justify-content: center;"
                    onclick="simulateGoogleLogin()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;">
                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12s4.477 10 10 10 10-4.477 10-10z"></path>
                        <path d="M12 8v4l3 3"></path>
                    </svg>
                    Continue with Google
                </button>
            </form>

            <div class="auth-footer">
                Already have an account? <a href="/auth" class="auth-link">Sign In</a>
            </div>
            <div class="auth-footer" style="margin-top: 10px;">
                <a href="/" class="auth-link" style="color: var(--gray-600); font-size: 0.85rem;">&larr; Back to Home</a>
            </div>
        </div>
    </div>

    <%- include('partials/theme-toggle') %>

    <script>
        function selectRole(role, element) {
            document.getElementById('selectedRoleInput').value = role;
            document.querySelectorAll('.role-card').forEach(card => card.classList.remove('selected'));
            element.classList.add('selected');
        }

        function simulateGoogleLogin() {
            const role = document.getElementById('selectedRoleInput').value;
            localStorage.setItem('campusphere-role', role);
            const btn = document.querySelector('.btn--primary');
            btn.innerHTML = `<svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px; animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> Authenticating...`;
            setTimeout(() => { window.location.href = '/dashboard'; }, 800);
        }

        const style = document.createElement('style');
        style.textContent = `@keyframes spin { 100% { transform: rotate(360deg); } }`;
        document.head.appendChild(style);
    </script>
</body>

</html>
