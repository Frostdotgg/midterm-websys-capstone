<!DOCTYPE html>

<html lang="en">



<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta name="description"

        content="CampusSphere Interactive Map — Navigate the CSPC campus with search, filtering, and floor plans.">

    <title>CampusSphere | Interactive Map</title>

    <link rel="stylesheet" href="/css/styles.css?v=2">

    <link rel="icon" type="image/png" href="/img/cspc-logo.png">

    <!-- Iconify -->

    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>



    <!-- Leaflet CSS & JS -->

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"

        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"

        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

</head>



<body>



    <!-- ===== NAVBAR ===== -->

    <nav class="dash-nav" id="dashNav">

        <div class="dash-nav__inner">

            <a href="/home" class="dash-nav__brand">

                <img src="/img/cspc-logo.png" alt="CSPC Logo" class="dash-nav__logo">

                <span class="dash-nav__title">CampusSphere</span>

            </a>

            <div class="dash-nav__tabs" id="dashTabs">

                <a href="/home" class="dash-nav__tab" id="tabHome">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">

                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />

                    </svg>

                    <span>Home</span>

                </a>

                <a href="/dashboard" class="dash-nav__tab" id="tabDashboard">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                        <rect x="3" y="3" width="7" height="7" />

                        <rect x="14" y="3" width="7" height="7" />

                        <rect x="14" y="14" width="7" height="7" />

                        <rect x="3" y="14" width="7" height="7" />

                    </svg>

                    <span>Dashboard</span>

                </a>

                <a href="/buildings" class="dash-nav__tab" id="tabBuildings">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                        stroke-linecap="round" stroke-linejoin="round">

                        <rect x="4" y="2" width="16" height="20" rx="2" />

                        <path d="M9 22v-4h6v4" />

                        <path d="M8 6h.01" />

                        <path d="M16 6h.01" />

                        <path d="M12 6h.01" />

                        <path d="M12 10h.01" />

                        <path d="M12 14h.01" />

                        <path d="M16 10h.01" />

                        <path d="M8 10h.01" />

                    </svg>

                    <span>Buildings</span>

                </a>

                <a href="/events" class="dash-nav__tab" id="tabEvents">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                        stroke-linecap="round" stroke-linejoin="round">

                        <rect x="3" y="4" width="18" height="18" rx="2" />

                        <line x1="16" y1="2" x2="16" y2="6" />

                        <line x1="8" y1="2" x2="8" y2="6" />

                        <line x1="3" y1="10" x2="21" y2="10" />

                    </svg>

                    <span>Events</span>

                </a>

                <a href="/map" class="dash-nav__tab dash-nav__tab--active" id="tabMap">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                        stroke-linecap="round" stroke-linejoin="round">

                        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />

                        <line x1="8" y1="2" x2="8" y2="18" />

                        <line x1="16" y1="6" x2="16" y2="22" />

                    </svg>

                    <span>Campus Map</span>

                </a>

                <a href="/about" class="dash-nav__tab" id="tabAbout">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                        stroke-linecap="round" stroke-linejoin="round">

                        <circle cx="12" cy="12" r="10" />

                        <line x1="12" y1="16" x2="12" y2="12" />

                        <line x1="12" y1="8" x2="12.01" y2="8" />

                    </svg>

                    <span>About Us</span>

                </a>

            </div>

            <!-- Right: Notification + User -->

            <div class="dash-nav__right">

                <button class="dash-nav__icon-btn" id="notifBtn" aria-label="Notifications">

                    <iconify-icon icon="ep:bell" width="20"></iconify-icon>

                    <span class="dash-nav__notif-dot"></span>

                </button>

                <div class="dash-nav__user" id="userMenu">

                    <div class="dash-nav__avatar">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"

                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />

                            <circle cx="12" cy="7" r="4" />

                        </svg>

                    </div>

                    <span class="dash-nav__username" id="navUsername">User</span>

                    <iconify-icon icon="ep:arrow-down" width="14" class="dash-nav__chevron"></iconify-icon>

                </div>

            </div>

            <button class="dash-nav__hamburger" aria-label="Toggle menu" id="dashHamburger">

                <span></span><span></span><span></span>

            </button>

        </div>

    </nav>



    <!-- ===== MAP PAGE LAYOUT ===== -->

    <div class="map-page">



        <!-- SIDEBAR -->

        <aside class="map-sidebar" id="mapSidebar">

            <div class="map-sidebar__header">

                <h2 class="map-sidebar__title">Find Location</h2>



                <!-- Search -->

                <div class="map-search">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                        stroke-linecap="round" stroke-linejoin="round">

                        <circle cx="11" cy="11" r="8" />

                        <line x1="21" y1="21" x2="16.65" y2="16.65" />

                    </svg>

                    <input type="text" class="map-search__input" id="mapSearchInput"

                        placeholder="Search buildings, rooms...">

                    <button class="map-search__clear" id="mapSearchClear">

                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"

                            stroke-width="2">

                            <line x1="18" y1="6" x2="6" y2="18" />

                            <line x1="6" y1="6" x2="18" y2="18" />

                        </svg>

                    </button>

                </div>



                <!-- Filters -->

                <div class="map-filters">

                    <button class="map-filter-btn active" data-filter="all">All</button>

                    <button class="map-filter-btn" data-filter="Academic">Academic</button>

                    <button class="map-filter-btn" data-filter="Administrative">Admin</button>

                    <button class="map-filter-btn" data-filter="Facilities">Facilities</button>

                </div>

            </div>



            <!-- List -->

            <div class="map-sidebar__list" id="bldgList">

                <!-- Rendered by JS -->

            </div>

        </aside>



        <!-- MAP CONTAINER -->

        <main class="map-container">



            <!-- The actual Map -->

            <div class="map-view" id="mapView"></div>



            <!-- Floating Info Panel -->

            <div class="map-panel" id="infoPanel">

                <button class="map-panel__close" id="closePanel">

                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                        <line x1="18" y1="6" x2="6" y2="18" />

                        <line x1="6" y1="6" x2="18" y2="18" />

                    </svg>

                </button>

                <img src="" alt="Building Image" class="map-panel__img" id="panelImg">

                <div class="map-panel__content">

                    <div class="map-panel__header">

                        <span class="map-bldg-item__cat" id="panelCat">Academic</span>

                        <h3 class="map-panel__title" id="panelTitle">Building Name</h3>

                    </div>

                    <p class="map-panel__desc" id="panelDesc">Building description goes here.</p>



                    <div class="map-panel__actions">

                        <div class="floor-switcher">

                            <button class="floor-btn" data-floor="1">1st Floor</button>

                            <button class="floor-btn active" data-floor="2">2nd Floor</button>

                            <button class="floor-btn" data-floor="3">3rd Floor</button>

                        </div>

                        <a href="/buildings" class="btn btn--primary btn--sm" style="margin-left:auto;">View

                            Details</a>

                    </div>

                </div>

            </div>



            <!-- Map Controls (Zoom, Geolocation, etc.) -->

            <div class="map-controls">

                <button class="map-ctrl-btn" title="My Location">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                        <polygon points="3 11 22 2 13 21 11 13 3 11" />

                    </svg>

                </button>

                <button class="map-ctrl-btn" title="Toggle Gates">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                        <path d="M4 2v20M20 2v20M4 10h16M4 14h16" />

                    </svg>

                </button>

            </div>



        </main>



        <!-- Mobile Toggle Button -->

        <button class="mobile-toggle-btn" id="mobileListToggle">

            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                <line x1="8" y1="6" x2="21" y2="6" />

                <line x1="8" y1="12" x2="21" y2="12" />

                <line x1="8" y1="18" x2="21" y2="18" />

                <line x1="3" y1="6" x2="3.01" y2="6" />

                <line x1="3" y1="12" x2="3.01" y2="12" />

                <line x1="3" y1="18" x2="3.01" y2="18" />

            </svg>

            Building List

        </button>



    </div>



    <!-- Theme Toggle -->

    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">

        <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"

            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

            <circle cx="12" cy="12" r="5" />

            <line x1="12" y1="1" x2="12" y2="3" />

            <line x1="12" y1="21" x2="12" y2="23" />

            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />

            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />

            <line x1="1" y1="12" x2="3" y2="12" />

            <line x1="21" y1="12" x2="23" y2="12" />

            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />

            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />

        </svg>

        <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"

            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">

            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />

        </svg>

    </button>



    <!-- App Data -->

    <script src="/js/data.js"></script>



    <script>

        // Use buildings data from data.js

        const mapBuildings = CampuSphereData.buildings || [];



        // DOM Elements

        const bldgList = document.getElementById('bldgList');

        const searchInput = document.getElementById('mapSearchInput');

        const searchClear = document.getElementById('mapSearchClear');

        const filterBtns = document.querySelectorAll('.map-filter-btn');



        const infoPanel = document.getElementById('infoPanel');

        const closePanelBtn = document.getElementById('closePanel');

        const panelImg = document.getElementById('panelImg');

        const panelCat = document.getElementById('panelCat');

        const panelTitle = document.getElementById('panelTitle');

        const panelDesc = document.getElementById('panelDesc');



        const mobileListToggle = document.getElementById('mobileListToggle');

        const mapSidebar = document.getElementById('mapSidebar');



        let currentFilter = 'all';

        let searchQuery = '';



        let leafletMap = null;

        let leafletMarkers = {};



        /* ===== RENDER BUILDING LIST ===== */

        function renderSidebar() {

            const filtered = mapBuildings.filter(b => {

                const matchFilter = currentFilter === 'all' || b.category === currentFilter;

                const matchSearch = b.name.toLowerCase().includes(searchQuery.toLowerCase());

                return matchFilter && matchSearch;

            });



            if (filtered.length === 0) {

                bldgList.innerHTML = `<p style="color:var(--gray-500);text-align:center;padding:1rem;">No buildings found.</p>`;

                return;

            }



            bldgList.innerHTML = filtered.map(b => `

                <div class="map-bldg-item" data-id="${b.id}" onclick="selectBuilding(${b.id})">

                    <img src="${b.img}" alt="${b.name}" class="map-bldg-item__img">

                    <div class="map-bldg-item__info">

                        <span class="map-bldg-item__name">${b.name}</span>

                        <span class="map-bldg-item__cat">${b.category}</span>

                    </div>

                </div>

            `).join('');

        }



        /* ===== SELECT BUILDING ===== */

        function selectBuilding(id) {

            const bldg = mapBuildings.find(b => b.id === id);

            if (!bldg) return;



            // Highlight sidebar list item

            document.querySelectorAll('.map-bldg-item').forEach(el => el.classList.remove('active'));

            const listItem = document.querySelector(`.map-bldg-item[data-id="${id}"]`);

            if (listItem) listItem.classList.add('active');



            // Pan map

            if (leafletMap && bldg.lat && bldg.lng) {

                leafletMap.flyTo([bldg.lat, bldg.lng], 18);

            }



            // Populate Info Panel

            panelImg.src = bldg.img;

            panelCat.textContent = bldg.category;

            panelTitle.textContent = bldg.name;

            panelDesc.textContent = bldg.desc;



            // Show Panel

            infoPanel.classList.add('visible');



            // Close sidebar on mobile

            if (window.innerWidth <= 768) {

                mapSidebar.classList.remove('open');

            }

        }



        /* ===== EVENT LISTENERS ===== */

        // Searching

        searchInput.addEventListener('input', (e) => {

            searchQuery = e.target.value;

            searchClear.style.display = searchQuery ? 'block' : 'none';

            renderSidebar();

        });



        searchClear.addEventListener('click', () => {

            searchInput.value = '';

            searchQuery = '';

            searchClear.style.display = 'none';

            renderSidebar();

        });



        // Filtering

        filterBtns.forEach(btn => {

            btn.addEventListener('click', () => {

                filterBtns.forEach(b => b.classList.remove('active'));

                btn.classList.add('active');

                currentFilter = btn.dataset.filter;

                renderSidebar();

            });

        });



        // Panel Close

        closePanelBtn.addEventListener('click', () => {

            infoPanel.classList.remove('visible');

            document.querySelectorAll('.map-bldg-item').forEach(el => el.classList.remove('active'));

        });



        // Mobile Sidebar Toggle

        mobileListToggle.addEventListener('click', () => {

            mapSidebar.classList.toggle('open');

        });



        // Floor Buttons

        document.querySelectorAll('.floor-btn').forEach(btn => {

            btn.addEventListener('click', (e) => {

                document.querySelectorAll('.floor-btn').forEach(b => b.classList.remove('active'));

                e.target.classList.add('active');

                // You would trigger changing the floorplan image / map layer here

            });

        });



        // Navbar Mobile

        document.getElementById('dashHamburger').addEventListener('click', () => {

            document.getElementById('dashHamburger').classList.toggle('active');

            document.getElementById('dashTabs').classList.toggle('open');

        });



        /* ===== THEME TOGGLE ===== */

        (function () {

            const toggle = document.getElementById('themeToggle');

            const iconSun = toggle.querySelector('.icon-sun');

            const iconMoon = toggle.querySelector('.icon-moon');



            function updateThemeUI(isDark) {

                if (isDark) {

                    document.documentElement.setAttribute('data-theme', 'dark');

                    iconSun.style.display = 'none';

                    iconMoon.style.display = 'block';

                } else {

                    document.documentElement.removeAttribute('data-theme');

                    iconSun.style.display = 'block';

                    iconMoon.style.display = 'none';

                }

            }



            if (localStorage.getItem('campussphere-theme') === 'dark') {

                updateThemeUI(true);

            }



            toggle.addEventListener('click', () => {

                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

                updateThemeUI(!isDark);

                localStorage.setItem('campussphere-theme', !isDark ? 'dark' : 'light');

            });

        })();



        /* ===== MAP INIT ===== */

        function initLeaflet() {

            leafletMap = L.map('mapView').setView([13.40591, 123.37362], 17);



            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {

                attribution: '&copy; OpenStreetMap contributors'

            }).addTo(leafletMap);



            const defaultIcon = L.icon({

                iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',

                iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',

                shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',

                iconSize: [25, 41],

                iconAnchor: [12, 41],

                popupAnchor: [1, -34],

                shadowSize: [41, 41]

            });



            mapBuildings.forEach(b => {

                if (b.lat && b.lng) {

                    const marker = L.marker([b.lat, b.lng], { icon: defaultIcon })

                        .addTo(leafletMap)

                        .bindTooltip(b.name);



                    marker.on('click', () => {

                        selectBuilding(b.id);

                    });



                    leafletMarkers[b.id] = marker;

                }

            });

        }



        /* ===== INIT ===== */

        initLeaflet();

        renderSidebar();



    </script>

    <!-- Edit Profile Script -->

    <script src="/js/profile-script.js"></script>

    <script src="/js/nav-role.js"></script>

</body>



</html>