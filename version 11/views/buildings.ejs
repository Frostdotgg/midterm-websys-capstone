                desc: 'The campus auditorium is a large venue for public events, seminars, conferences, cultural shows, and graduation ceremonies. Open to guests during scheduled events.',

                img: 'img/Camarines-sur-polytechnic-colleges.png',

                routes: ['Enter through the Main Gate and walk straight for 150 meters.', 'Turn right after the Main Academic Building.', 'Continue along the wide walkway for about 80 meters.', 'The Auditorium is the large building with a prominent entrance canopy on your left.'],

                walkTime: '5 min walk', landmarks: ['Main Gate', 'Main Academic Building', 'Wide Walkway'],

                floors: [

                    { label: 'Main Hall', rooms: [{ num: 'Stage', use: 'Performance Area' }, { num: 'Audience Seating', use: '500-capacity' }, { num: 'Sound Booth', use: 'Audio/Visual Control' }, { num: 'Backstage', use: 'Performer Prep' }, { num: 'Lobby', use: 'Reception Area' }, { num: 'Comfort Rooms', use: 'CR M/F' }] },

                    { label: 'Balcony', rooms: [{ num: 'Upper Seating', use: '200-capacity' }, { num: 'Lighting Booth', use: 'Lighting Control' }, { num: 'Projection Room', use: 'AV Equipment' }] }

                ],

                entrances: ['Main Entrance — Front Lobby', 'Side Entrance — East Wing (Performers)', 'Emergency Exit — Rear (North Side)', 'Balcony Access — Lobby Stairwell'],

                info: ['2 Levels (Main Hall + Balcony)', 'Capacity: ~700 seated', 'Professional sound & lighting', 'Venue for graduation ceremonies', 'Available: By reservation, Mon – Sat']

            }

        ];



        /* ===== TAG COLORS ===== */

        const TAG_CLASS = { Academic: 'tag--academic', Administrative: 'tag--admin', Facilities: 'tag--facilities' };

        const TAG_STYLE = { Academic: 'background:rgba(30,77,140,.15);color:var(--navy-700)', Administrative: 'background:rgba(212,168,67,.2);color:#7a4f00', Facilities: 'background:rgba(22,163,74,.15);color:#15803d' };



        /* ===== RENDER GRID ===== */

        let currentFilter = 'all';

        let currentQuery = '';



        function renderGrid(filter = currentFilter, query = currentQuery) {

            currentFilter = filter;

            currentQuery = query;

            const grid = document.getElementById('bldgGrid');

            const empty = document.getElementById('emptyState');

            const countEl = document.getElementById('bldgCount');

            const q = query.toLowerCase().trim();

            let filtered = filter === 'all' ? BUILDINGS : BUILDINGS.filter(b => b.category === filter);

            if (q) filtered = filtered.filter(b => b.name.toLowerCase().includes(q) || b.desc.toLowerCase().includes(q));

            countEl.textContent = filtered.length + ' building' + (filtered.length !== 1 ? 's' : '');

            if (!filtered.length) { grid.innerHTML = ''; empty.style.display = 'block'; return; }

            empty.style.display = 'none';

            const role = localStorage.getItem('campusphere-role') || 'guest';

            const isGuest = role === 'guest';

            grid.innerHTML = filtered.map(b => `

        <div class="bldg-card" data-id="${b.id}">

            <div class="bldg-card__img">

                <img src="${b.img}" alt="${b.name}" loading="lazy">

                <span class="bldg-card__tag ${TAG_CLASS[b.category]}">${b.category}</span>

                ${isGuest && !b.guestAccess ? '<span class="bldg-card__restricted-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Restricted</span>' : ''}

            </div>

            <div class="bldg-card__body">

                <div class="bldg-card__name">${b.name}</div>

                <p class="bldg-card__desc">${b.desc}</p>

                <div class="bldg-card__footer">

                    <button class="bldg-card__btn bldg-card__btn--primary" onclick="openModal(${b.id});event.stopPropagation()">View Details</button>

                    <button class="bldg-card__btn bldg-card__btn--routes" onclick="openRouteModal(${b.id});event.stopPropagation()">View Routes</button>

                </div>

            </div>

        </div>`).join('');

            grid.querySelectorAll('.bldg-card').forEach(c => c.addEventListener('click', () => openModal(+c.dataset.id)));

        }



        /* ===== FILTER BUTTONS ===== */

        document.getElementById('filterBar').querySelectorAll('.bldg-filter-btn').forEach(btn => {

            btn.addEventListener('click', () => {

                document.querySelectorAll('.bldg-filter-btn').forEach(b => b.classList.remove('active'));

                btn.classList.add('active');

                renderGrid(btn.dataset.filter, currentQuery);

            });

        });



        /* ===== SEARCH ===== */

        const searchInput = document.getElementById('bldgSearch');

        const searchClear = document.getElementById('bldgSearchClear');



        searchInput.addEventListener('input', () => {

            const q = searchInput.value;

            searchClear.classList.toggle('visible', q.length > 0);

            renderGrid(currentFilter, q);

        });



        searchClear.addEventListener('click', () => {

            searchInput.value = '';

            searchClear.classList.remove('visible');

            renderGrid(currentFilter, '');

            searchInput.focus();

        });



        /* ===== MODAL ===== */

        let activeBuilding = null, activeFloor = 0;



        function openModal(id) {

            const b = BUILDINGS.find(x => x.id === id);

            if (!b) return;

            activeBuilding = b; activeFloor = 0;

            document.getElementById('modalTitle').textContent = b.name;

            const tag = document.getElementById('modalTag');

            tag.textContent = b.category; tag.style.cssText = TAG_STYLE[b.category] + ';padding:.2rem .65rem;border-radius:999px;font-size:.7rem;font-weight:700;text-transform:uppercase;';

            // Floors

            const sel = document.getElementById('floorSelector');

            sel.innerHTML = b.floors.map((f, i) => `<button class="floor-btn ${i === 0 ? 'active' : ''}" data-fi="${i}">${f.label}</button>`).join('');

            sel.querySelectorAll('.floor-btn').forEach(btn => btn.addEventListener('click', () => {

                sel.querySelectorAll('.floor-btn').forEach(b => b.classList.remove('active'));

                btn.classList.add('active'); renderFloor(+btn.dataset.fi);

            }));

            renderFloor(0);

            // Entrances

            document.getElementById('modalEntrances').innerHTML = b.entrances.map(e => `<li>${e}</li>`).join('');

            // Info

            document.getElementById('modalInfo').innerHTML = b.info.map(i => `<li>${i}</li>`).join('');

            document.getElementById('modalOverlay').classList.add('open');

            document.body.style.overflow = 'hidden';

        }



        function renderFloor(fi) {

            const floor = activeBuilding.floors[fi];

            document.getElementById('floorPlanHeader').textContent = floor.label + ' — Room Layout';

            document.getElementById('floorPlanRooms').innerHTML = floor.rooms.map(r =>

                `<div class="room-block"><span class="room-block__num">${r.num}</span><span class="room-block__use">${r.use}</span></div>`).join('');

        }



        function closeModal() {

            document.getElementById('modalOverlay').classList.remove('open');

            document.body.style.overflow = '';

        }



        document.getElementById('modalClose').addEventListener('click', closeModal);

        document.getElementById('modalOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

        document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModal(); closeRouteModal(); } });



        /* ===== ROUTE MODAL ===== */

        function openRouteModal(id) {

            const b = BUILDINGS.find(x => x.id === id);

            if (!b) return;

            const role = localStorage.getItem('campusphere-role') || 'guest';

            const isGuest = role === 'guest';

            const restricted = isGuest && !b.guestAccess;

            document.getElementById('routeModalTitle').textContent = 'Routes to ' + b.name;

            document.getElementById('routeModalSubtitle').textContent = 'Walking directions from Main Gate • ' + (b.walkTime || '~5 min');

            let html = '';

            if (restricted) {

                html += `<div class="route-restricted-warning">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>

                    <div class="route-restricted-warning__text">

                        <strong>Restricted Access — Guests Cannot Enter</strong>

                        This building is restricted to authorized personnel (students, faculty, or staff) only. You may view the exterior and surroundings but entry is not permitted for guests.

                    </div>

                </div>`;

            }

            html += '<div class="route-info-label">Walking Directions</div>';

            html += '<div class="route-time"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' + (b.walkTime || '~5 min') + '</div>';

            html += '<ol class="route-steps">';

            (b.routes || []).forEach((step, i) => {

                html += `<li class="route-step"><span class="route-step__num">${i + 1}</span><span class="route-step__text">${step}</span></li>`;

            });

            html += '</ol>';

            if (b.landmarks && b.landmarks.length) {

                html += '<div class="route-landmarks"><div class="route-info-label">Nearby Landmarks</div><ul class="route-landmark-list">';

                b.landmarks.forEach(l => { html += `<li>${l}</li>`; });

                html += '</ul></div>';

            }

            document.getElementById('routeModalBody').innerHTML = html;

            document.getElementById('routeModalOverlay').classList.add('open');

            document.body.style.overflow = 'hidden';

        }



        function closeRouteModal() {

            document.getElementById('routeModalOverlay').classList.remove('open');

            document.body.style.overflow = '';

        }



        document.getElementById('routeModalClose').addEventListener('click', closeRouteModal);

        document.getElementById('routeModalOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeRouteModal(); });



        /* ===== NAVBAR ===== */

        const dashNav = document.getElementById('dashNav');

        window.addEventListener('scroll', () => dashNav.classList.toggle('scrolled', scrollY > 10));

        const hamburger = document.getElementById('dashHamburger');

        const tabs = document.getElementById('dashTabs');

        hamburger.addEventListener('click', () => { hamburger.classList.toggle('active'); tabs.classList.toggle('open'); });



        /* ===== USERNAME FROM localStorage ===== */

        (function () {

            const role = localStorage.getItem('campusphere-role') || 'guest';

            const names = { 'student-cspc': 'Aaron', 'student-non-cspc': 'Student', 'instructor': 'Dr. Santos', 'admin': 'Admin', 'guest': 'Guest' };

            document.getElementById('navUsername').textContent = names[role] || 'User';

        })();



        /* ===== THEME ===== */

        (function () {

            const toggle = document.getElementById('themeToggle');

            if (localStorage.getItem('campussphere-theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');

            toggle.addEventListener('click', () => {

                const dark = document.documentElement.getAttribute('data-theme') === 'dark';

                dark ? document.documentElement.removeAttribute('data-theme') : document.documentElement.setAttribute('data-theme', 'dark');

                localStorage.setItem('campussphere-theme', dark ? 'light' : 'dark');

            });

        })();



        /* ===== INIT ===== */

        renderGrid();

    </script>

    <!-- Edit Profile Script -->

    <script src="/js/profile-script.js"></script>

    <script src="/js/nav-role.js"></script>

</body>



</html>