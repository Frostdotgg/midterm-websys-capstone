    <!-- ===== PAGE ===== -->

    <div class="bldg-page">



        <!-- Hero -->

        <div class="bldg-hero">

            <img src="/img/campus-hero.jpg" alt="CSPC Campus">

            <div class="bldg-hero__overlay"></div>

            <div class="bldg-hero__content">

                <h1 class="bldg-hero__title">Campus Buildings</h1>

                <p class="bldg-hero__sub">Explore all facilities — click any building to view floors, rooms, and

                    entrances.</p>

            </div>

        </div>



        <!-- Main -->

        <div class="bldg-main">



            <!-- Search bar -->

            <div class="bldg-search-wrap">

                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"

                    stroke-linecap="round" stroke-linejoin="round">

                    <circle cx="11" cy="11" r="8" />

                    <line x1="21" y1="21" x2="16.65" y2="16.65" />

                </svg>

                <input class="bldg-search" id="bldgSearch" type="search"

                    placeholder="Search buildings by name or description…" autocomplete="off">

                <button class="bldg-search-clear" id="bldgSearchClear" aria-label="Clear search">✖</button>

            </div>



            <!-- Filter bar -->

            <div class="bldg-filters" id="filterBar">

                <button class="bldg-filter-btn active" data-filter="all">All Buildings</button>

                <button class="bldg-filter-btn" data-filter="Academic">

                    <span

                        style="width:8px;height:8px;border-radius:50%;background:var(--navy-500);display:inline-block;"></span>Academic

                </button>

                <button class="bldg-filter-btn" data-filter="Administrative">

                    <span

                        style="width:8px;height:8px;border-radius:50%;background:var(--gold);display:inline-block;"></span>Administrative

                </button>

                <button class="bldg-filter-btn" data-filter="Facilities">

                    <span

                        style="width:8px;height:8px;border-radius:50%;background:var(--green-accent);display:inline-block;"></span>Facilities

                </button>

                <span class="bldg-count" id="bldgCount"></span>

            </div>



            <!-- Grid -->

            <div class="bldg-grid" id="bldgGrid"></div>



            <!-- Empty state -->

            <div class="bldg-empty" id="emptyState">

                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">

                    <rect x="4" y="2" width="16" height="20" rx="2" />

                    <path d="M9 22v-4h6v4" />

                </svg>

                <p>No buildings match this filter.</p>

            </div>

        </div>

    </div>



    <!-- ===== BUILDING DETAIL MODAL ===== -->

    <div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true" aria-labelledby="modalTitle">

        <div class="modal" id="modal">

            <div class="modal__header">

                <div>

                    <div class="modal__title" id="modalTitle">Building Name</div>

                    <span class="modal__tag" id="modalTag"></span>

                </div>

                <button class="modal__close" id="modalClose" aria-label="Close">✖</button>

            </div>

            <div class="modal__body">



                <!-- Floor plan panel -->

                <div class="floor-panel">

                    <div class="floor-panel__label">Floor Plan</div>

                    <div class="floor-selector" id="floorSelector"></div>

                    <div class="floor-plan-box">

                        <div class="floor-plan-header" id="floorPlanHeader">Ground Floor</div>

                        <div class="floor-plan-rooms" id="floorPlanRooms"></div>

                    </div>

                </div>



                <!-- Info grid -->

                <div class="info-grid">

                    <div class="info-section">

                        <div class="info-section__title">Entrances &amp; Exits</div>

                        <ul class="info-list" id="modalEntrances"></ul>

                    </div>

                    <div class="info-section">

                        <div class="info-section__title">Key Information</div>

                        <ul class="info-list" id="modalInfo"></ul>

                    </div>

                </div>



            </div>

        </div>

    </div>



