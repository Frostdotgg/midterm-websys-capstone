<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
        <!-- Leaflet CSS & JS -->
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
            integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        <!-- Iconify -->
        <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
</head>

<body>

    <!-- ===== DASHBOARD NAVBAR ===== -->
    <%- include('partials/dash-navbar') %>

        <!-- ===== HERO BANNER ===== -->
        <section class="dash-hero" id="dashHero">
            <div class="dash-hero__bg">
                <img src="/img/campus-hero.jpg" alt="CSPC Campus">
                <div class="dash-hero__overlay"></div>
            </div>
            <div class="dash-hero__content">
                <h1 class="dash-hero__title">Welcome to CampusSphere</h1>
                <p class="dash-hero__subtitle">Explore the campus easily using the interactive map.</p>
                <div class="dash-hero__actions">
                    <a href="/map" class="btn btn--primary btn--hero">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                            <line x1="8" y1="2" x2="8" y2="18" />
                            <line x1="16" y1="6" x2="16" y2="22" />
                        </svg>
                        Open Campus Map
                    </a>
                    <a href="/buildings" class="btn btn--white btn--hero">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
                            <path d="M9 22v-4h6v4" />
                            <path d="M8 6h.01" />
                            <path d="M16 6h.01" />
                            <path d="M12 6h.01" />
                            <path d="M12 10h.01" />
                        </svg>
                        View Buildings
                    </a>
                </div>
            </div>
        </section>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="dash-main">
            <div class="dash-main__inner">
                <!-- LEFT COLUMN -->
                <div class="dash-main__left">
                    <!-- Search Bar -->
                    <div class="dash-search" id="searchSection">
                        <div class="dash-search__bar">
                            <svg class="dash-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            <input type="text" class="dash-search__input" id="searchInput" placeholder="Search Campus"
                                autocomplete="off">
                        </div>
                    </div>

                    <!-- Quick Access Cards -->
                    <div class="dash-quick" id="quickAccess">
                        <a href="/map" class="dash-quick__card">
                            <div class="dash-quick__card-icon dash-quick__card-icon--map">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                    <circle cx="12" cy="10" r="3" />
                                </svg>
                            </div>
                            <div class="dash-quick__card-info">
                                <strong>Campus Map</strong>
                                <small>Navigate Campus Location</small>
                            </div>
                        </a>
                        <a href="/buildings" class="dash-quick__card">
                            <div class="dash-quick__card-icon dash-quick__card-icon--building">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
                                    <path d="M9 22v-4h6v4" />
                                    <path d="M8 6h.01" />
                                    <path d="M16 6h.01" />
                                    <path d="M12 6h.01" />
                                    <path d="M12 10h.01" />
                                </svg>
                            </div>
                            <div class="dash-quick__card-info">
                                <strong>Buildings</strong>
                                <small>View all campus facilities</small>
                            </div>
                        </a>
                        <a href="/events" class="dash-quick__card">
                            <div class="dash-quick__card-icon dash-quick__card-icon--event">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                            </div>
                            <div class="dash-quick__card-info">
                                <strong>Events</strong>
                                <small>Check out upcoming events</small>
                            </div>
                        </a>
                        <a href="#" class="dash-quick__card">
                            <div class="dash-quick__card-icon dash-quick__card-icon--office">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                    <polyline points="9 22 9 12 15 12 15 22" />
                                </svg>
                            </div>
                            <div class="dash-quick__card-info">
                                <strong>Offices</strong>
                                <small>Find administrative offices</small>
                            </div>
                        </a>
                    </div>

                    <!-- Campus Map Preview -->
                    <div class="dash-map-preview" id="mapPreview">
                        <div class="dash-map-preview__header">
                            <h3 class="dash-map-preview__title">Campus Map</h3>
                            <a href="/map" class="btn btn--primary btn--sm">Open Full Map</a>
                        </div>
                        <div class="dash-map-preview__container">
                            <div id="homeLeafletMap" style="width:100%; height:350px; border-radius: 12px; z-index: 1;">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN (Sidebar) -->
                <div class="dash-main__right">
                    <!-- Featured Locations -->
                    <div class="dash-sidebar-card" id="featuredLocations">
                        <div class="dash-sidebar-card__header">
                            <h3 class="dash-sidebar-card__title">Featured Locations</h3>
                            <a href="/buildings" class="dash-sidebar-card__link">View All</a>
                        </div>
                        <div class="dash-sidebar-card__body">
                            <div class="location-item">
                                <div class="location-item__img">
                                    <img src="/img/Camarines-sur-polytechnic-colleges.png" alt="CCS Building">
                                </div>
                                <div class="location-item__info">
                                    <strong class="location-item__name">CCS Building</strong>
                                    <small class="text-xs text-muted-foreground"
                                        style="display:block; margin-bottom:6px;">College of Computer Studies</small>
                                    <div class="location-item__actions">
                                        <a href="/map" class="btn--tag btn--tag-primary">View on Map</a>
                                        <a href="/buildings" class="btn--tag btn--tag-outline">Details</a>
                                    </div>
                                </div>
                            </div>
                            <div class="location-item">
                                <div class="location-item__img">
                                    <img src="/img/Camarines-sur-polytechnic-colleges.png" alt="Library Building">
                                </div>
                                <div class="location-item__info">
                                    <strong class="location-item__name">Library Building</strong>
                                    <small class="text-xs text-muted-foreground"
                                        style="display:block; margin-bottom:6px;">Campus Academic Resources</small>
                                    <div class="location-item__actions">
                                        <a href="/map" class="btn--tag btn--tag-primary">View on Map</a>
                                        <a href="/buildings" class="btn--tag btn--tag-outline">Details</a>
                                    </div>
                                </div>
                            </div>
                            <div class="location-item">
                                <div class="location-item__img">
                                    <img src="/img/Camarines-sur-polytechnic-colleges.png" alt="Engineering Building">
                                </div>
                                <div class="location-item__info">
                                    <strong class="location-item__name">Engineering Building</strong>
                                    <small class="text-xs text-muted-foreground"
                                        style="display:block; margin-bottom:6px;">Laboratories & Drawing Rooms</small>
                                    <div class="location-item__actions">
                                        <a href="/map" class="btn--tag btn--tag-primary">View on Map</a>
                                        <a href="/buildings" class="btn--tag btn--tag-outline">Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Upcoming Events -->
                    <div class="dash-sidebar-card" id="upcomingEvents">
                        <div class="dash-sidebar-card__header">
                            <h3 class="dash-sidebar-card__title">Upcoming Events</h3>
                            <a href="/events" class="dash-sidebar-card__link">View All</a>
                        </div>
                        <div class="dash-sidebar-card__body">
                            <div class="event-item">
                                <div class="event-item__date">
                                    <span class="event-item__day">25</span>
                                    <span class="event-item__month">March 25</span>
                                </div>
                                <div class="event-item__info">
                                    <strong class="event-item__name">CSPC Foundation Week</strong>
                                    <small class="event-item__time">8:00 AM - 5:00 PM</small>
                                </div>
                            </div>
                            <div class="event-item">
                                <div class="event-item__date">
                                    <span class="event-item__day">05</span>
                                    <span class="event-item__month">April 05</span>
                                </div>
                                <div class="event-item__info">
                                    <strong class="event-item__name">IT Skills Competition</strong>
                                    <small class="event-item__time">9:00 AM - 3:00 PM</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- ===== FOOTER ===== -->
        <%- include('partials/dash-footer') %>

            <!-- ===== SCRIPTS ===== -->
            <script>
                // ---- Dashboard Navbar scroll ----
                const dashNav = document.getElementById('dashNav');
                window.addEventListener('scroll', () => {
                    dashNav.classList.toggle('scrolled', window.scrollY > 10);
                });

                // ---- Mobile hamburger ----
                const dashHamburger = document.getElementById('dashHamburger');
                const dashTabs = document.getElementById('dashTabs');
                dashHamburger.addEventListener('click', () => {
                    dashHamburger.classList.toggle('active');
                    dashTabs.classList.toggle('open');
                });
                dashTabs.querySelectorAll('.dash-nav__tab').forEach(tab => {
                    tab.addEventListener('click', () => {
                        dashHamburger.classList.remove('active');
                        dashTabs.classList.remove('open');
                    });
                });

                // ---- Search functionality ----
                const searchInput = document.getElementById('searchInput');
                const quickCards = document.querySelectorAll('.dash-quick__card');
                searchInput.addEventListener('input', (e) => {
                    const query = e.target.value.toLowerCase();
                    quickCards.forEach(card => {
                        const text = card.textContent.toLowerCase();
                        card.style.display = text.includes(query) ? '' : 'none';
                    });
                });
            </script>

            <%- include('partials/theme-toggle') %>

                <!-- Edit Profile Script -->
                <script src="/js/profile-script.js"></script>
                <script src="/js/nav-role.js"></script>
                <script src="/js/data.js"></script>
                <script>
                    // Initialize Home Page Map
                    document.addEventListener('DOMContentLoaded', () => {
                        const map = L.map('homeLeafletMap').setView([13.40591, 123.37362], 17);

                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                        }).addTo(map);

                        // Add building markers from CampuSphereData
                        if (typeof CampuSphereData !== 'undefined' && CampuSphereData.buildings) {
                            CampuSphereData.buildings.forEach(b => {
                                if (b.lat && b.lng) {
                                    L.marker([b.lat, b.lng])
                                        .addTo(map)
                                        .bindPopup(`<strong>${b.name}</strong><br>${b.category}`);
                                }
                            });
                        }
                    });
                </script>
</body>

</html>