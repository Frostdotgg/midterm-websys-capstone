<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="auth-page" style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
    <div class="auth-card" style="text-align:center;max-width:480px;">
      <div style="font-size:4rem;margin-bottom:1rem;"><%= statusCode === 404 ? '🔍' : '⚠️' %></div>
      <h1 class="auth-title" style="font-size:2rem;margin-bottom:0.5rem;"><%= statusCode %></h1>
      <p class="auth-subtitle" style="margin-bottom:1.5rem;"><%= message %></p>
      <a href="/" class="btn btn--primary" style="display:inline-flex;justify-content:center;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Back to Home
      </a>
    </div>
  </div>

  <%- include('partials/theme-toggle') %>
</body>
</html>
